  object qryReport: TQuery
    DatabaseName = 'wt'
    SQL.Strings = (
      
        'select Sales_Order.*, Operator.Operator_Name, Operator.Telephone' +
        '_number'
      'from Sales_Order, Operator'
      'where Sales_Order = :Sales_Order and'
      'Sales_Order.Operator = Operator.Operator')
    Left = 379
    Top = 110
    ParamData = <
      item
        DataType = ftInteger
        Name = 'Sales_Order'
        ParamType = ptUnknown
      end>
  end
