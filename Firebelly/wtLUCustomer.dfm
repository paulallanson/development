  object qryCustomers: TFDQuery
    ConnectionName = 'wt'
    SQL.Strings = (
      'SELECT  Customer.*,'
      '        Customer_Type.Description,'
      '        Payment_Terms.Payment_Terms_Description'
      'FROM Payment_Terms'
      '      RIGHT JOIN (Customer_Type'
      '      INNER JOIN Customer'
      '        ON Customer_Type.Customer_Type = Customer.Customer_type)'
      '        ON Payment_Terms.Payment_Terms = Customer.Payment_Terms'
      'where Customer_Name LIKE :Name AND'
      '((Not_Active = :Not_Active) or (Not_Active = '#39'N'#39'))'
      'Order By Customer_Name '
      ' ')
    Left = 120
    Top = 200
    ParamData = <
      item
        Name = 'Name'
        DataType = ftString
        ParamType = ptInput
      end
      item
        Name = 'Not_Active'
        ParamType = ptInput
      end>
  end
  object dtsCustomers: TDataSource
    DataSet = qryCustomers
    Left = 192
    Top = 200
  end
  object qryDelete: TFDQuery
    ConnectionName = 'WT'
    SQL.Strings = (
      'delete '
      'from customer'
      'where customer = :Customer')
    Left = 472
    Top = 128
    ParamData = <
      item
        Name = 'Customer'
      end>
  end
  object qryDummy: TFDQuery
    ConnectionName = 'wt'
    SQL.Strings = (
      'SELECT  Customer.*,'
      '        Customer_Type.Description,'
      '        Payment_Terms.Payment_Terms_Description,'
      '        (SELECT top 1 Sales_invoice.Invoice_Date'
      '         FROM Sales_Invoice'
      '         WHERE (Sales_invoice.Customer = Customer.Customer) AND'
      '            (Sales_invoice.Goods_Value > 0)'
      
        '         ORDER BY Sales_Invoice.Sales_Invoice desc) as Last_Sale' +
        's_Invoice,'
      '        lop.Importance_Description,'
      '        lop.Color,'
      '        lop.Font_Color'
      'FROM (Payment_Terms'
      '      RIGHT JOIN (Customer_Type'
      '      INNER JOIN Customer'
      '        ON Customer_Type.Customer_Type = Customer.Customer_type)'
      '        ON Payment_Terms.Payment_Terms = Customer.Payment_Terms)'
      '      LEFT JOIN Level_of_Importance lop'
      
        '        ON Customer.Level_of_Importance = lop.Level_of_Importanc' +
        'e'
      'WHERE'
      '((Not_Active = :Not_Active) or (Not_Active = '#39'N'#39'))'
      ''
      ''
      ' ')
    Left = 280
    Top = 200
    ParamData = <
      item
        Name = 'Not_Active'
        DataType = ftString
        ParamType = ptInput
      end>
  end
