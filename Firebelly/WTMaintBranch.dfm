  object qryGetLastNo: TFDQuery
    ConnectionName = 'wt'
    SQL.Strings = (
      'select Max(Branch_No) as Last_no'
      'from Customer_Branch'
      'where Customer = :Customer')
    Left = 408
    Top = 8
    ParamData = <
      item
        Name = 'Customer'
      end>
  end
  object qryAdd: TFDQuery
    ConnectionName = 'wt'
    SQL.Strings = (
      'Insert into Customer_Branch'
      '(Customer,'
      'Branch_no,'
      'Branch_Name,'
      'Address,'
      'Installation_Contact,'
      'Site_QS_Contact,'
      'Special_Instructions'
      ')'
      'Values'
      '(:Customer,'
      ':Branch_no,'
      ':Branch_Name,'
      ':Address,'
      ':Installation_Contact,'
      ':Site_QS_Contact,'
      ':Special_Instructions'
      ')')
    Left = 368
    Top = 104
    ParamData = <
      item
        Name = 'Customer'
      end
      item
        Name = 'Branch_no'
      end
      item
        Name = 'Branch_Name'
      end
      item
        Name = 'Address'
      end
      item
        Name = 'Installation_Contact'
        DataType = ftInteger
      end
      item
        Name = 'Site_QS_Contact'
        DataType = ftInteger
      end
      item
        Name = 'Special_Instructions'
        DataType = ftInteger
      end>
  end
  object qryUpd: TFDQuery
    ConnectionName = 'wt'
    SQL.Strings = (
      'Update Customer_Branch'
      'set Branch_Name = :Branch_Name,'
      '    Address = :Address,'
      '    Installation_Contact = :Installation_Contact,'
      '    Site_QS_Contact = :Site_QS_Contact,'
      '    Special_Instructions = :Special_Instructions'
      'where Customer = :Customer and Branch_no = :Branch_no')
    Left = 368
    Top = 152
    ParamData = <
      item
        Name = 'Branch_Name'
      end
      item
        Name = 'Address'
      end
      item
        Name = 'Installation_Contact'
        DataType = ftInteger
      end
      item
        Name = 'Site_QS_Contact'
        DataType = ftInteger
      end
      item
        Name = 'Special_Instructions'
        DataType = ftInteger
      end
      item
        Name = 'Customer'
      end
      item
        Name = 'Branch_no'
      end>
  end
  object qryDel: TFDQuery
    ConnectionName = 'wt'
    SQL.Strings = (
      'delete from Customer_Branch'
      'where Customer = :Customer and Branch_no = :Branch_no')
    Left = 368
    Top = 56
    ParamData = <
      item
        Name = 'Customer'
      end
      item
        Name = 'Branch_no'
      end>
  end
  object qryGetBranch: TFDQuery
    ConnectionName = 'WT'
    SQL.Strings = (
      'SELECT *'
      'FROM Customer_Branch'
      'WHERE Customer = :Customer AND'
      '               Branch_No = :Branch_No')
    Left = 24
    Top = 8
    ParamData = <
      item
        Name = 'Customer'
      end
      item
        Name = 'Branch_No'
      end>
  end
  object qryGetAddress: TFDQuery
    ConnectionName = 'WT'
    SQL.Strings = (
      'SELECT *'
      'FROM Address'
      'WHERE Address = :Address')
    Left = 24
    Top = 72
    ParamData = <
      item
        Name = 'Address'
      end>
  end
  object qryAddAddress: TFDQuery
    ConnectionName = 'wT'
    SQL.Strings = (
      'insert into Address'
      '(Address,'
      'Address_name,'
      'Street,'
      'Locale,'
      'Town_city,'
      'Postcode,'
      'County_state,'
      'telephone_number,'
      'email_address,'
      'Installation_Address)'
      'values'
      '(:Address,'
      ':Address_name,'
      ':Street,'
      ':Locale,'
      ':Town_city,'
      ':Postcode,'
      ':County_state,'
      ':Telephone_number,'
      ':email_address,'
      ':Installation_Address)')
    Left = 24
    Top = 128
    ParamData = <
      item
        Name = 'Address'
      end
      item
        Name = 'Address_name'
      end
      item
        Name = 'Street'
      end
      item
        Name = 'Locale'
      end
      item
        Name = 'Town_city'
      end
      item
        Name = 'Postcode'
      end
      item
        Name = 'County_state'
      end
      item
        Name = 'Telephone_number'
      end
      item
        Name = 'email_address'
      end
      item
        Name = 'Installation_Address'
        DataType = ftString
      end>
  end
  object qryUpAddress: TFDQuery
    ConnectionName = 'wT'
    SQL.Strings = (
      'update Address'
      'set'
      '  Address_Name = :Address_Name,'
      '  Street = :Street,'
      '  Locale = :Locale,'
      '  Town_City = :Town_City,'
      '  Postcode = :Postcode,'
      '  County_State = :County_State,'
      '  Telephone_number = :Telephone_number,'
      '  Email_Address = :email_Address'
      'where Address = :Address')
    Left = 48
    Top = 128
    ParamData = <
      item
        Name = 'Address_Name'
      end
      item
        Name = 'Street'
      end
      item
        Name = 'Locale'
      end
      item
        Name = 'Town_City'
      end
      item
        Name = 'Postcode'
      end
      item
        Name = 'County_State'
      end
      item
        Name = 'Telephone_number'
      end
      item
        Name = 'email_Address'
      end
      item
        Name = 'Address'
      end>
  end
  object qryGetNextAdd: TFDQuery
    ConnectionName = 'wt'
    SQL.Strings = (
      'select max(address) as Last_Address'
      'from Address')
    Left = 104
    Top = 8
  end
  object qryContacts: TFDQuery
    ConnectionName = 'WT'
    SQL.Strings = (
      'SELECT Contact_no, Contact_name'
      'FROM Customer_Contact'
      'WHERE Customer = :Customer AND'
      '      ((inactive IS NULL) or (inactive = '#39'N'#39'))'
      'ORDER BY Contact_Name')
    Left = 176
    Top = 200
    ParamData = <
      item
        Name = 'Customer'
      end>
  end
