  object WorktopSQL: TFDQuery
    ConnectionName = 'WT'
    MasterSource = MaterialSRC
    Params.Data = {010001000D4D6174657269616C5F7479706500000000}
    SQL.Strings = (
      'select worktop,'
      #9#9#9'Worktop.Description,'
      '        Stocked,'
      '        Use_For_Estimating'
      'from worktop'
      'where worktop.stocked = '#39'Y'#39' and '
      '          worktop.Material_type = :Material_type'
      'order by Worktop.Description')
    Left = 24
    Top = 81
    object WorktopSQLworktop: TStringField
      FieldName = 'worktop'
      Size = 8
    end
    object WorktopSQLDescription: TStringField
      FieldName = 'Description'
      Size = 40
    end
    object WorktopSQLStocked: TStringField
      FieldName = 'Stocked'
      Size = 1
    end
    object WorktopSQLUse_For_Estimating: TStringField
      FieldName = 'Use_For_Estimating'
      Size = 1
    end
  end
  object WorktopSRC: TDataSource
    DataSet = WorktopSQL
    Left = 88
    Top = 81
  end
  object Thickness: TFDQuery
    ConnectionName = 'WT'
    MasterSource = WorktopSRC
    Params.Data = {
      01000200074E6577446174650000000007776F726B746F700001020030000100}
    SQL.Strings = (
      'select distinct Worktop_thickness.*, '
      '          Thickness.Thickness_mm,'
      ' '#9#9#9#9'(select top 1 Unit_Price'
      '           from prices'
      
        '           where (prices.price_pointer = Worktop_Thickness.Price' +
        '_pointer) and'
      '           '#9'(effective_date <= :NewDate)'
      '           order by effective_date desc) as Unit_Price'
      'from Worktop_thickness, thickness, Prices'
      'where (worktop = :worktop) AND'
      
        '           (Worktop_Thickness.Thickness = Thickness.Thickness) A' +
        'ND'
      
        '           (Worktop_Thickness.Price_Pointer = Prices.Price_Point' +
        'er)'
      'order by Thickness.Thickness_mm')
    Left = 24
    Top = 136
  end
