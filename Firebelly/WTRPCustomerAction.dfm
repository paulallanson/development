  object qryReport: TFDQuery
    ConnectionName = 'Wt'
    SQL.Strings = (
      'SELECT  Customer.Customer,'
      '        Customer.Customer_type,'
      '        Customer_Type.Description as Customer_Type_Description,'
      '        Customer.Customer_name,'
      '        Customer.Telephone_number,'
      '        Customer.Rep,'
      '        Rep.Rep_Name,'
      '        Customer.Prospect,'
      '        Customer.Prospect_Action,'
      '        Prospect_Action.Prospect_Action_Description,'
      '        Customer.Contact_no,'
      '        Customer.Prospect_Action_Next_Date,'
      '        Customer.Prospect_Action_Operator,'
      '        Operator.Operator_Name,'
      '        (select Customer_Contact.Contact_Name'
      '         from Customer_Contact'
      '         where Customer_Contact.Customer = Customer.Customer and'
      
        '               Customer_Contact.Contact_no = Customer.Contact_no' +
        ') as Contact_name'
      'FROM Rep'
      '    RIGHT JOIN (Customer_Type'
      '    INNER JOIN (Operator'
      '    INNER JOIN (Prospect_Action'
      '    INNER JOIN Customer'
      
        '      ON Prospect_Action.Prospect_Action = Customer.Prospect_Act' +
        'ion)'
      '      ON Operator.Operator = Customer.Prospect_Action_Operator)'
      '      ON Customer_Type.Customer_Type = Customer.Customer_type)'
      '      ON Rep.Rep = Customer.Rep'
      'WHERE'
      
        '((Customer.Prospect_Action_Operator = :Operator) or (0 = :Operat' +
        'or)) and'
      '((Customer.Prospect_Action = :Code) or (0 = :Code)) and'
      
        '((Customer.Prospect_Action_Next_Date >= :Date_From) and (Custome' +
        'r.Prospect_Action_Next_Date <= :Date_To)) and'
      
        '((Customer.not_active is NULL) or (Customer.not_active = '#39'N'#39') or' +
        ' (customer.not_active = '#39#39'))'
      
        'ORDER BY Prospect_Action.Prospect_Action_Description, Customer.P' +
        'rospect_Action_Next_Date')
    Left = 208
    Top = 184
    ParamData = <
      item
        DataType = ftUnknown
        Name = 'Operator'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'Operator'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'Code'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'Code'
        ParamType = ptUnknown
      end
      item
        DataType = ftDateTime
        Name = 'Date_From'
        ParamType = ptUnknown
      end
      item
        DataType = ftDateTime
        Name = 'Date_To'
        ParamType = ptUnknown
      end>
  end
end
