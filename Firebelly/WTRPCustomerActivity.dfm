  object qryReport: TQuery
    DatabaseName = 'Wt'
    SQL.Strings = (
      'SELECT DISTINCT'
      '      Customer.Customer,'
      '      Customer.Customer_name,'
      '      Customer.Date_Created,'
      '      Rep.Rep_Name,'
      '      Customer_Type.Description as Customer_Type_description'
      'FROM Customer_Type'
      '    INNER JOIN (Rep'
      '    RIGHT JOIN (Customer'
      '    INNER JOIN Customer_Event'
      '      ON Customer.Customer = Customer_Event.Customer)'
      '      ON Rep.Rep = Customer.Rep)'
      '      ON Customer_Type.Customer_Type = Customer.Customer_type'
      'WHERE ((Customer.Customer = :Customer) or (:Customer = 0)) and'
      '      ((Customer.Rep = :Rep) or (:Rep = 0)) and'
      
        '      ((Customer_event.date_time_entered >= :Date_From) and (Cus' +
        'tomer_event.date_time_entered <= :Date_To))'
      'ORDER BY Rep.Rep_Name, Customer.Customer_Name')
    Left = 208
    Top = 184
    ParamData = <
      item
        DataType = ftUnknown
        Name = 'Customer'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'Customer'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'Rep'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'Rep'
        ParamType = ptUnknown
      end
      item
        DataType = ftDateTime
        Name = 'Date_From'
        ParamType = ptUnknown
      end
      item
        DataType = ftDateTime
        Name = 'Date_To'
        ParamType = ptUnknown
      end>
  end
  object qryActivity: TQuery
    DatabaseName = 'wt'
    SQL.Strings = (
      'select Top 1 Customer_Event.Date_Time_Entered'
      'from Customer_Event'
      'where Customer = :Customer'
      'Order by Customer_Event.Date_Time_Entered desc')
    Left = 206
    Top = 257
    ParamData = <
      item
        DataType = ftUnknown
        Name = 'Customer'
        ParamType = ptUnknown
      end>
  end
  object qryQuotes: TQuery
    DatabaseName = 'wt'
    SQL.Strings = (
      'select count(Quote) as Quote_Count'
      'from Quote'
      'where Quote.Customer = :Customer and'
      
        'Quote.Date_Raised >= :Date_From and Quote.Date_Raised <= :Date_T' +
        'o')
    Left = 206
    Top = 329
    ParamData = <
      item
        DataType = ftUnknown
        Name = 'Customer'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'Date_From'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'Date_To'
        ParamType = ptUnknown
      end>
  end
  object qrySOrders: TQuery
    DatabaseName = 'wt'
    SQL.Strings = (
      
        'select count(sales_order) as Order_Count, sum(Goods_Value) as To' +
        'tal_Sales'
      'from Sales_Order'
      'where Sales_Order.Customer = :Customer and'
      
        'Sales_order.Date_Raised >= :Date_From and Sales_Order.Date_Raise' +
        'd <= :Date_To')
    Left = 206
    Top = 393
    ParamData = <
      item
        DataType = ftUnknown
        Name = 'Customer'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'Date_From'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'Date_To'
        ParamType = ptUnknown
      end>
  end
  object qrySInvoices: TQuery
    DatabaseName = 'wt'
    SQL.Strings = (
      
        'select count(sales_Invoice) as Invoice_Count, sum(Goods_Value) a' +
        's Total_Invoice'
      'from Sales_Invoice'
      'where Sales_Invoice.Customer = :Customer and'
      
        'Sales_Invoice.Invoice_Date >= :Date_From and Sales_Invoice.Invoi' +
        'ce_Date <= :Date_To')
    Left = 206
    Top = 449
    ParamData = <
      item
        DataType = ftUnknown
        Name = 'Customer'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'Date_From'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'Date_To'
        ParamType = ptUnknown
      end>
  end
  object qryActivityDetails: TQuery
    DatabaseName = 'wt'
    SQL.Strings = (
      'select Customer_Event.Date_Time_Entered,'
      '        Operator.Operator_Name,'
      '        Customer_Contact.Contact_Name,'
      '        Event_Title,'
      '        Narrative'
      'from customer_event, operator, customer_contact'
      'where Customer_Event.Customer = :Customer and'
      
        'Date_Time_Entered >= :Date_From and Date_Time_Entered <= :Date_t' +
        'o and'
      '(customer_event.operator = operator.operator) and'
      '('
      '(customer_event.customer = customer_Contact.customer) and'
      '(customer_event.contact_no = customer_Contact.contact_no)'
      ')'
      'ORDER BY Customer_Event.Customer_Event_no')
    Left = 336
    Top = 328
    ParamData = <
      item
        DataType = ftUnknown
        Name = 'Customer'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'Date_From'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'Date_to'
        ParamType = ptUnknown
      end>
  end
