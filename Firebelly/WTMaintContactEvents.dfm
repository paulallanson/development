  object AddSQL: TFDQuery
    ConnectionName = 'wt'
    SQL.Strings = (
      'Insert Into Customer_Event'
      '        (Customer,'
      '        Contact_No,'
      '        Customer_Event_No,'
      '        Event_Title,'
      '        Operator)'
      
        'Select :Customer, :Contact_No, Max(Customer_Event_No)+1, :Event_' +
        'Title, :Operator'
      'From Customer_Event'
      ' '
      ' ')
    Left = 48
    Top = 240
    ParamData = <
      item
        Name = 'Customer'
        DataType = ftInteger
        ParamType = ptInput
      end
      item
        Name = 'Contact_No'
      end
      item
        Name = 'Event_Title'
      end
      item
        Name = 'Operator'
      end>
  end
  object UpdSQL: TFDQuery
    ConnectionName = 'wt'
    SQL.Strings = (
      'Update Customer_Event'
      'Set'
      'Date_Time_Entered = :Date_Time_Entered,'
      'Narrative = :Narrative,'
      'Operator = :Operator,'
      'Event_Title = :Event_Title,'
      'Contact_no = :Contact_no,'
      'Customer = :Customer,'
      'Prospect_Action = :Prospect_Action'
      'Where'
      '(Customer_Event_No = :Customer_Event_No)'
      ''
      ''
      ' '
      ' ')
    Left = 120
    Top = 240
    ParamData = <
      item
        Name = 'Date_Time_Entered'
      end
      item
        Name = 'Narrative'
        DataType = ftInteger
      end
      item
        Name = 'Operator'
      end
      item
        Name = 'Event_Title'
      end
      item
        Name = 'Contact_No'
      end
      item
        Name = 'Customer'
      end
      item
        Name = 'Prospect_Action'
        DataType = ftInteger
      end
      item
        Name = 'Customer_Event_No'
      end>
  end
  object DelSQL: TFDQuery
    ConnectionName = 'wt'
    SQL.Strings = (
      'Delete From Customer_Event'
      'Where'
      '(Customer = :Customer) and'
      '(Contact_No = :Contact_No) and'
      '(Customer_Event_No = :Customer_Event_No)'
      ' ')
    Left = 48
    Top = 176
    ParamData = <
      item
        Name = 'Customer'
      end
      item
        Name = 'Contact_No'
      end
      item
        Name = 'Customer_Event_No'
      end>
  end
  object qryContacts: TFDQuery
    ConnectionName = 'wt'
    SQL.Strings = (
      'Select Customer, Contact_no, Contact_Name'
      'From Customer_Contact'
      'where Customer = :Customer'
      'Order By Contact_Name')
    Left = 48
    Top = 116
    ParamData = <
      item
        Name = 'Customer'
        DataType = ftInteger
      end>
  end
  object dtsContacts: TDataSource
    DataSet = qryContacts
    Left = 120
    Top = 116
  end
  object QryZero: TFDQuery
    ConnectionName = 'wt'
    SQL.Strings = (
      'Insert Into Customer_Contact'
      '        (Customer,'
      '        Branch_No,'
      '        Contact_No,'
      '        Name,'
      '        Contact_Type)'
      
        'Select :Customer, :Branch_No, Max(Contact_No)+1, :Event_GUID, :C' +
        'ontact_Type'
      
        'From Customer_Contact Where Customer = :Customer and Branch_No =' +
        ' :Branch_No'
      ''
      ''
      ' ')
    Left = 224
    Top = 120
    ParamData = <
      item
        Name = 'Customer'
      end
      item
        Name = 'Branch_No'
