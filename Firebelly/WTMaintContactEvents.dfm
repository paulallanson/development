        ')'
      '        INNER JOIN Customer'
      '          ON Customer_Event.Customer = Customer.Customer)'
      '          ON Operator.Operator = Customer_Event.Operator'
      'WHERE Customer_Event.Customer_Event_no = :Customer_Event_no')
