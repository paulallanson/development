  object qryGetStore: TFDQuery
    ConnectionName = 'WT'
    SQL.Strings = (
      'SELECT  Store.Store,'
      '        Store.Address,'
      '        Store.inactive,'
      '        Address.Address_name,'
      '        Address.Street,'
      '        Address.Locale,'
