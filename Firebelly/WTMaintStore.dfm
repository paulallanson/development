  object qryGetLastNo: TFDQuery
    ConnectionName = 'wt'
    SQL.Strings = (
      'select Max(Store) as Last_no'
      'from Store')
    Left = 408
    Top = 8
  end
  object qryAdd: TFDQuery
    ConnectionName = 'wt'
    SQL.Strings = (
      'Insert into Store'
      '(Store,'
      'Address,'
      'inactive'
      ')'
      'Values'
      '(:Store,'
      ':Address,'
      ':inactive'
      ')')
    Left = 408
    Top = 104
    ParamData = <
      item
        Name = 'Store'
      end
      item
        Name = 'Address'
      end
      item
        Name = 'inactive'
      end>
  end
  object qryUpd: TFDQuery
    ConnectionName = 'wt'
    SQL.Strings = (
      'Update Store'
      'set Address = :Address,'
      '    inactive = :inactive'
      'where Store = :Store')
    Left = 408
    Top = 152
    ParamData = <
      item
        Name = 'Address'
      end
      item
        Name = 'inactive'
      end
      item
        Name = 'Store'
      end>
  end
  object qryDel: TFDQuery
    ConnectionName = 'wt'
    SQL.Strings = (
      'delete from Store'
      'where Store = :Store')
    Left = 408
    Top = 56
    ParamData = <
      item
        Name = 'Store'
      end>
  end
  object qryGetAddress: TFDQuery
    ConnectionName = 'WT'
    SQL.Strings = (
      'SELECT *'
      'FROM Address'
      'WHERE Address = :Address')
    Left = 310
    Top = 130
    ParamData = <
      item
        Name = 'Address'
      end>
  end
  object qryAddAddress: TFDQuery
    ConnectionName = 'wT'
    SQL.Strings = (
      'insert into Address'
      '(Address,'
      'Address_name,'
      'Street,'
      'Locale,'
      'Town_city,'
      'Postcode,'
      'County_state,'
      'telephone_number,'
      'email_address,'
      'Installation_Address)'
      'values'
      '(:Address,'
      ':Address_name,'
      ':Street,'
      ':Locale,'
      ':Town_city,'
      ':Postcode,'
      ':County_state,'
      ':Telephone_number,'
      ':email_address,'
      ':Installation_Address)')
    Left = 360
    Top = 130
    ParamData = <
      item
        Name = 'Address'
      end
      item
        Name = 'Address_name'
      end
      item
        Name = 'Street'
      end
      item
        Name = 'Locale'
      end
      item
        Name = 'Town_city'
      end
      item
        Name = 'Postcode'
      end
      item
        Name = 'County_state'
      end
      item
        Name = 'Telephone_number'
      end
      item
        Name = 'email_address'
      end
      item
        Name = 'Installation_Address'
        DataType = ftString
      end>
  end
  object qryUpAddress: TFDQuery
    ConnectionName = 'wT'
    SQL.Strings = (
      'update Address'
      'set'
      '  Address_Name = :Address_Name,'
      '  Street = :Street,'
      '  Locale = :Locale,'
      '  Town_City = :Town_City,'
      '  Postcode = :Postcode,'
      '  County_State = :County_State,'
      '  Telephone_number = :Telephone_number,'
      '  Email_Address = :email_Address'
      'where Address = :Address')
    Left = 410
    Top = 138
    ParamData = <
      item
        Name = 'Address_Name'
      end
      item
        Name = 'Street'
      end
      item
        Name = 'Locale'
      end
      item
        Name = 'Town_City'
      end
      item
        Name = 'Postcode'
      end
      item
        Name = 'County_State'
      end
      item
        Name = 'Telephone_number'
      end
      item
        Name = 'email_Address'
      end
      item
        Name = 'Address'
      end>
  end
