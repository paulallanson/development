  object qryQOptions: TQuery
    DatabaseName = 'Wt'
    DataSource = dtsReport
    SQL.Strings = (
      'SELECT DISTINCT'
      '  Quote.Quote,'
      '  Quote.Nett_Price,'
      '  Quote.Discount_Value,'
      '  Quote.Quote_Number,'
      '  Quote.Markup_Value,'
      '  Quote.Installation_Price,'
      '  Quote.Survey_Price,'
      '  Quote.Delivery_Price,'
      '  Quote.Original_Quote,'
      '  Worktop.Description as Worktop_Description,'
