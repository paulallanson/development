  object qryAdd: TFDQuery
    ConnectionName = 'WT'
    SQL.Strings = (
      'Insert Into Worktop_Finish'
      '        (Worktop_Finish,'
      '        Description)'
      'Select Max(Worktop_Finish)+1, :GUID'
      'From Worktop_Finish'
      ' ')
    Left = 632
