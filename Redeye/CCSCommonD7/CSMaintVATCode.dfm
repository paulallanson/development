  object CheckUniqueRefSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Select VAT_Code'
      'From VAT_Code'
      'Where (VAT_Code <> :VAT_Code) and'
      '      (VAT_Ref = :VAT_Ref)')
    Left = 232
    Top = 64
    ParamData = <
      item
        Name = 'VAT_Code'
      end
      item
        Name = 'VAT_Ref'
      end>
  end
