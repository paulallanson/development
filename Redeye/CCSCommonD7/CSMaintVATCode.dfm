      end
      item
        Name = 'Description'
      end
      item
        Name = 'VAT_Ref'
      end>
  end
  object UpdSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Update VAT_Code'
      'Set'
      'Description = :Description,'
      'VAT_Rate = :VAT_Rate,'
      'VAT_Ref = :VAT_Ref'
      'Where VAT_Code = :VAT_Code')
    Left = 144
    Top = 16
    ParamData = <
      item
        Name = 'Description'
      end
      item
        Name = 'VAT_Rate'
      end
      item
        Name = 'VAT_Ref'
      end
      item
        Name = 'VAT_Code'
      end>
  end
  object DelSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Delete From VAT_Code'
      'Where'
      '(VAT_Code = :VAT_Code)')
    Left = 240
    Top = 16
    ParamData = <
