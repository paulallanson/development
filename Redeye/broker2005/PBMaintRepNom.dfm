  object GetLastSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Select Max(Nominal_Reference) as Last_Code'
      'From Rep_Nominal'
      'Where Rep =:Rep')
    Left = 32
    Top = 96
    ParamData = <
      item
        Name = 'Rep'
        DataType = ftInteger
      end>
  end
  object AddSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Insert Into Rep_Nominal'
      '        (Rep,'
      '         Nominal_Reference,'
      '         Nominal,'
      '         Nominal_Description)'
      'Values'
      '         (:Rep,'
      '          :Nominal_Reference,'
      '          :Nominal,'
      '          :Nominal_Description)'
      '     '
      '       '
      '      ')
    Left = 168
    Top = 104
    ParamData = <
      item
        Name = 'Rep'
        DataType = ftInteger
      end
      item
        Name = 'Nominal_Reference'
        DataType = ftInteger
      end
      item
        Name = 'Nominal'
        DataType = ftString
      end
      item
        Name = 'Nominal_Description'
        DataType = ftString
      end>
  end
  object UpdSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Update Rep_Nominal'
      'Set'
      '            Nominal =:Nominal,'
      '            Nominal_Description =:Nominal_Description'
      'Where Rep =:Rep and'
      '            Nominal_Reference =:Nominal_Reference'
      '       ')
    Left = 88
    Top = 104
    ParamData = <
      item
        Name = 'Nominal'
        DataType = ftString
      end
      item
        Name = 'Nominal_Description'
        DataType = ftString
      end
      item
        Name = 'Rep'
        DataType = ftInteger
      end
      item
        Name = 'Nominal_Reference'
        DataType = ftInteger
      end>
  end
  object DelSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Delete From Rep_Nominal'
      'Where'
      '(Rep = :Rep) and'
      '(Nominal_Reference = :Nominal_Reference)')
    Left = 128
    Top = 88
    ParamData = <
      item
        Name = 'Rep'
        DataType = ftInteger
      end
      item
        Name = 'Nominal_Reference'
      end>
  end
