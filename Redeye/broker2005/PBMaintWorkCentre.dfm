      'Running_Speed = 0,'
      'Running_Speed_unit = 1,'
      'Hourly_Rate = :Hourly_Rate,'
      'Minimum_Width_mm = 0,'
      'Minimum_depth_mm = 0,'
      'Maximum_depth_mm = 0,'
      'Maximum_width_mm = 0,'
      'Feed_Method = :Feed_Method,'
      'Estimating_name = :Estimating_Name,'
      'Work_Centre_Description = :Work_Centre_Description,'
      'Click_Charge = :Click_Charge '
      'Where (Work_Centre = :Work_Centre) '
      ''
      ' ')
