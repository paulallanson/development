  object DetsSRC: TDataSource
    DataSet = GetDetsSQL
    OnDataChange = DetsSRCDataChange
    Left = 136
    Top = 24
  end
  object GetDetsSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Select  Part_Store.*'
      'From Part_Store'
      'Where (Part_Store.Part_Store_Name Like :Code_From) and'
      
        '      ((Inactive = '#39'N'#39') or (Inactive is NULL) or (Inactive = :In' +
        'active))'
      'Order By Part_Store.Part_Store_Name'
      ' '
      ' '
      ' '
      ' '
      ' ')
    Left = 64
    Top = 64
    ParamData = <
      item
        Name = 'Code_From'
      end
      item
        Name = 'Inactive'
      end>
  end
