    DatabaseName = 'PB'
    SQL.Strings = (
      'Select Name'
      'From Customer_Contact'
      'Where (Customer = :Customer) and'
      '      (Branch_No = :Branch_No) and'
      '      (Contact_No = :Contact_No)  ')
    Left = 161
    Top = 360
    ParamData = <
