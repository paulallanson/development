  object GetCompSQL: TQuery
    DatabaseName = 'PB'
    SQL.Strings = (
      'Select * from Company'
      'Where Company = 1')
    Left = 184
    Top = 78
  end
  object CustSQL: TQuery
    DatabaseName = 'PB'
    SQL.Strings = (
