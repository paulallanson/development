  object qryInsAddChrg: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Insert into Additional_Charge'
      '  (Additional_charge,'
      '  Details,'
      '  Amount,'
      '  Quotation_Price)'
      'values'
      '  (:Additional_charge,'
      '  :Details,'
      '  :Amount,'
      '  :Quotation_price);'
      ' ')
