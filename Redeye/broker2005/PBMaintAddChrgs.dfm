    Top = 16
    ParamData = <
      item
        Name = 'Additional_charge'
      end
      item
        Name = 'Details'
      end
      item
        Name = 'Amount'
      end
      item
        Name = 'Quotation_price'
      end>
  end
  object qryUpdAddChrg: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Update additional_charge'
      'set Details = :Details,'
      '    Amount = :Amount,'
      '    Quotation_Price = :Quotation_Price'
      'where additional_charge = :additional_charge;'
      ' ')
    Left = 168
    Top = 16
    ParamData = <
      item
        Name = 'Details'
      end
      item
        Name = 'Amount'
      end
      item
        Name = 'Quotation_Price'
      end
      item
        Name = 'additional_charge'
      end>
  end
  object qryDelAddChrge: TFDQuery
