  object DetsSRC: TDataSource
    DataSet = GetDetsSQL
    Left = 136
    Top = 24
  end
  object GetDetsSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Select Process_Operation.*'
      'From Process_Operation'
      
        'Where (Process_Operation.Operation_Description Like :Code_From) ' +
        'and'
      '      (Process_Operation.Process = :Process) and'
      
        '((Process_Operation.Inactive = '#39'N'#39') or (Process_Operation.Inacti' +
        've is NULL) or (Process_Operation.Inactive = :Inactive))'
      'Order By Process_Operation.Sequence_no, Operation_Description'
      '')
    Left = 200
    Top = 24
    ParamData = <
      item
        Name = 'Code_From'
        DataType = ftString
      end
      item
        Name = 'Process'
      end
      item
        Name = 'Inactive'
      end>
  end
  object SearchTimer: TTimer
    Enabled = False
    Interval = 250
    OnTimer = SearchTimerTimer
    Left = 200
    Top = 152
  end
