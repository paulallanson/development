  object GetBinsSQL: TQuery
    DatabaseName = 'PB'
    Left = 256
    Top = 200
  end
  object GetBinsPartSQL: TQuery
    DatabaseName = 'PB'
    SQL.Strings = (
      
        'Select Store_Stock.Part_Bin, Max(Part_Store_Bin.Bin_Can_Pick) as' +
        ' Bin_Can_Pick,'
      
        '                             Sum(Store_Stock.Store_Quantity) as ' +
        'Bin_Qty'
      'from Store_Stock, Part_Store_Bin'
      'Where (Store_Stock.Part_Store = :Part_Store) and'
      '      (Part = :Part) and'
      '      (Part_Store_Bin.Part_Bin = Store_Stock.Part_Bin)'
      'Group By Store_Stock.Part_Bin'
      'Order By Store_Stock.Part_Bin'
      '')
    Left = 128
    Top = 200
    ParamData = <
      item
        DataType = ftUnknown
        Name = 'Part_Store'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'Part'
        ParamType = ptUnknown
      end>
  end
  object GetBinsHadPartSQL: TQuery
    DatabaseName = 'PB'
    SQL.Strings = (
      'Select Part_Movement.Part_Movement_Bin As Part_Bin,'
      '       Max(Part_Store_Bin.Bin_Can_Pick) as Bin_Can_Pick,'
      '       (Select Sum(Store_Stock.Store_Quantity)'
      '           From Store_Stock'
