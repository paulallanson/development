  object qrySelParts: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'select part.part,'
      ' part.Part_Description '
      'from part '
      'where (customer = :cust)'
      ' and ((part.part like :part) or (:part = '#39#39'))'
      ' and ((part.not_in_use = '#39'N'#39') or (:all_parts = '#39'Y'#39')) '
      'order by part '
      ' '
      ' ')
    Left = 44
    Top = 100
    ParamData = <
      item
        Name = 'cust'
        DataType = ftInteger
        ParamType = ptInput
      end
      item
        Name = 'part'
        DataType = ftString
        ParamType = ptInput
      end
      item
        Name = 'part'
        DataType = ftString
        ParamType = ptInput
      end
      item
        Name = 'all_parts'
        DataType = ftString
        ParamType = ptInput
      end>
  end
  object dtsrcParts: TDataSource
    DataSet = qrySelParts
    Left = 136
    Top = 100
  end
