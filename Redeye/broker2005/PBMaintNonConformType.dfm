  object AddSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Insert Into Non_Conform_Type'
      '        (Non_Conform_Type,'
      '        Non_Conform_Type_Descr)'
      'Select Max(Non_Conform_Type)+1, :GUID'
      'From Non_Conform_Type')
    Left = 264
    Top = 24
    ParamData = <
      item
        Name = 'GUID'
        DataType = ftString
        ParamType = ptInput
      end>
  end
  object UpdSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Update Non_Conform_Type'
      
        'Set Non_Conform_Type_Descr = :Non_Conform_Type_Descr, inactive =' +
        ' :inactive'
      'Where (Non_Conform_Type = :Non_Conform_Type) '
      ''
      ' ')
    Left = 208
    Top = 24
    ParamData = <
      item
        Name = 'Non_Conform_Type_Descr'
      end
      item
        Name = 'inactive'
      end
      item
        Name = 'Non_Conform_Type'
      end>
  end
