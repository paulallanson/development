  object GetGroupsQuery: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Select Customer_Discount.*, Part_Group.Part_Group_descr_short,'
      '  Part_Group.Part_Group'
      'From Customer_Discount'
      
        'left join Part_Group on Part_Group.Part_Group = Customer_Discoun' +
        't.Part_Group'
      'Where ((Customer_Discount.Customer = :Customer) and'
      
        '  ((Customer_Discount.Supplier = :Supplier) or (:Supplier = 0)) ' +
        'and'
      '  (Customer_Discount.Part is null))'
      'Order By customer_discount.Part_Group'
      ''
      ''
      ''
      ''
      ' '
      ' '
      ' '
      ' '
      ' '
      ' '
      ' ')
    Left = 272
    Top = 224
    ParamData = <
      item
        Name = 'Customer'
      end
      item
        Name = 'Supplier'
      end
      item
        Name = 'Supplier'
      end>
  end
  object GetPartsQuery: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Select Customer_Discount.*, Part.Part_description'
      
        'From Customer_Discount left join Part on Part.Part = Customer_Di' +
        'scount.Part'
      'Where ((Customer_Discount.Customer = :Customer) and'
      '  ((Customer_Discount.Supplier = :Supplier)) and'
      '  (Customer_Discount.Part is not null))'
      'Order By Customer_Discount.Part'
      ''
      ''
      ''
      ' '
      ' '
      ' '
      ' ')
    Left = 184
    Top = 224
    ParamData = <
      item
        Name = 'Customer'
      end
      item
        Name = 'Supplier'
      end>
  end
end
