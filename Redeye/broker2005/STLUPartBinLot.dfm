  object DetsSRC: TDataSource
    DataSet = GetDetsSQL
    Left = 136
    Top = 24
  end
  object GetDetsSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Select  Part,'
      '        Part_Bin,'
      '        Invoice_Upfront,'
      '        Part_Store_Lot,'
      '        (Store_Quantity - Quantity_Allocated) as Free_Stock'
      'from Store_Stock'
      'WHERE Part = :Part AND'
      '      Part_Bin = :Part_Bin'
      'ORDER BY Part_Store_Lot')
    Left = 64
    Top = 64
    ParamData = <
      item
        Name = 'Part'
      end
      item
        Name = 'Part_Bin'
      end>
  end
end
