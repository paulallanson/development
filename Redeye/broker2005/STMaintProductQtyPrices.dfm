  object qryGetQtyPrices: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'SELECT '#9'Part_Quantity_Price.Part,'
      #9'Part_Quantity_Price.Quantity, '
      #9'Part_Quantity_Price.Sell_Price, '
      #9'Part_Quantity_Price.Cost_Price, '
      #9'Part_Quantity_Price.Sell_Pack_Quantity, '
      #9'Part_Quantity_Price.Purch_Pack_Quantity, '
      #9'Part_Quantity_Price.Supplier, '
      #9'Part_Quantity_Price.Sell_Unit, '
      #9'Part_Quantity_Price.Cost_Unit, '
      #9'Supplier.Name as Supplier_Name, '
      #9'Sell_Unit.Description as Sell_Price_Unit, '
      #9'Cost_Unit.Description as Cost_Price_Unit'
      'FROM Supplier '
      #9'INNER JOIN (Price_Unit AS Cost_Unit '
      #9'RIGHT JOIN (Price_Unit AS Sell_Unit '
      #9'RIGHT JOIN Part_Quantity_Price '
      #9#9'ON Sell_Unit.Price_Unit = Part_Quantity_Price.Sell_Unit) '
      #9#9'ON Cost_Unit.Price_Unit = Part_Quantity_Price.Cost_Unit) '
      #9#9'ON Supplier.Supplier = Part_Quantity_Price.Supplier'
      'WHERE Part = :Part')
    Left = 224
    Top = 112
    ParamData = <
      item
        Name = 'Part'
      end>
  end
  object qryDel: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'delete from Part_Quantity_Price'
      'where Part = :Part')
    Left = 360
    Top = 112
    ParamData = <
      item
        Name = 'Part'
      end>
  end
  object qryAdd: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'insert into Part_Quantity_Price'
      '  (Part,'
      '  Quantity,'
      '  Sell_Price,'
      '  Cost_Price,'
      '  Sell_Pack_Quantity,'
      '  Purch_Pack_Quantity,'
      '  Supplier,'
      '  Sell_Unit,'
      '  Cost_Unit)'
      'values'
      '  (:Part,'
      '  :Quantity,'
      '  :Sell_Price,'
      '  :Cost_Price,'
      '  :Sell_Pack_Quantity,'
      '  :Purch_Pack_Quantity,'
      '  :Supplier,'
      '  :Sell_Unit,'
      '  :Cost_Unit)')
    Left = 440
    Top = 112
    ParamData = <
      item
        Name = 'Part'
      end
      item
        Name = 'Quantity'
      end
      item
        Name = 'Sell_Price'
      end
      item
        Name = 'Cost_Price'
      end
      item
        Name = 'Sell_Pack_Quantity'
      end
      item
        Name = 'Purch_Pack_Quantity'
      end
      item
        Name = 'Supplier'
      end
      item
        Name = 'Sell_Unit'
      end
      item
        Name = 'Cost_Unit'
      end>
  end
  object qrySuppliers: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'select * from supplier'
      'where (Acc_Active = '#39'Y'#39')'
      'ORDER BY Name')
    Left = 528
    Top = 120
  end
  object dtsSupplier: TDataSource
    DataSet = qrySuppliers
    Left = 584
    Top = 120
  end
  object qryPriceUnit: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'select *'
      'from price_unit'
      
        'where ((price_unit_inactive = '#39'N'#39') or (price_unit_inactive is NU' +
        'LL))'
      'order by Description')
    Left = 536
    Top = 256
  end
  object dtsPriceUnit: TDataSource
    DataSet = qryPriceUnit
    Left = 584
    Top = 256
  end
