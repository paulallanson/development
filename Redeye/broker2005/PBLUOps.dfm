  object DetsSRC: TDataSource
    DataSet = GetDetsSQL
    Left = 120
    Top = 72
  end
  object GetDetsSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Select  Operator,'
      '        Name,'
      '        Login_Name,'
      '        Short_Name,'
      '        Operator_Can_login,'
      '        Rep,'
      '        security_user,'
      '        Max_Unauthorised_PO_Value,'
      '        Authorised_PO_Cost_Limit, '
      '        Email,'
      '        Min_PO_Sales_Value_Type,'
      '        Min_PO_Sales_Value,'
      '        Delete_PO_From_Job_Bag,'
      '        Maintain_PO_in_Job_Bag,'
      '        Can_Pass_Purchase_Invoices,'
      '        Override_Paid_Stock,'
      '        Can_Authorise_PO,'
      '        Cannot_View_Enq_Prices,'
      '        Can_Convert_Enquiry,'
      '        Phone,'
      '        Mobile_no,'
      '        Can_Delete_Purchase_Orders,'
      '        Can_Delete_Job_Bags,'
      '        Can_Deactivate_Products,'
      '        web_ordering_email,'
      '        Can_Confirm_Production,'
      '        Cannot_Change_Rep,'
      '        Can_Change_Invoiced_Orders,'
      '        Can_Update_Credit_Details,'
      '        Activity_Administrator,'
      '        Job_Title,'
      '        Set_Enquiry_Reminder,'
      '        Set_Quote_Reminder,'
      '        Set_Proof_Reminder,'
      '        Set_Reorder_Reminder,'
      '        Set_Order_Ack_Reminder,'
      '        Set_Delivery_Reminder,'
      '        Can_Delete_Quote_Costs'
      'From Operator'
      'where (Name Like :Code_From) and'
      
        '((Operator_Can_login = '#39'Y'#39') or (Operator_Can_login is NULL) or (' +
        'Operator_Can_login = :Operator_Can_login))'
      'Order By Login_Name'
      ' ')
    Left = 32
    Top = 48
    ParamData = <
      item
        Name = 'Code_From'
      end
      item
        Name = 'Operator_Can_login'
      end>
  end
  object qryCheckOpBtns: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'select * from operator_button'
      'where button_name like '#39'mnu%'#39)
    Left = 216
    Top = 72
  end
  object SearchTimer: TTimer
    Enabled = False
    Interval = 250
    OnTimer = SearchTimerTimer
    Left = 200
    Top = 152
  end
