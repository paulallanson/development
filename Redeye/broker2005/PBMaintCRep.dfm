  object UpdSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Update Reps_Branches'
      'Set'
      '        Percentage = :Percentage,'
      'Is_Main_Rep = :Is_Main_Rep'
      'Where'
      '(Customer = :Customer) and'
      '(Branch_No = :Branch_No) and'
      '(Rep = :Rep)'
      '')
    Left = 304
    ParamData = <
      item
        Name = 'Percentage'
      end
      item
        Name = 'Is_Main_Rep'
        DataType = ftString
      end
      item
        Name = 'Customer'
      end
      item
        Name = 'Branch_No'
      end
      item
        Name = 'Rep'
      end>
  end
  object AddSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Insert Into Reps_Branches'
      '        (Customer,'
      '        Branch_No,'
      '        Rep,'
      '        Percentage,'
      '        Is_Main_Rep)'
      'Values'
      '        (:Customer,'
      '        :Branch_No,'
      '        :Rep,'
      '        :Percentage,'
      '        :Is_Main_Rep)'
      '')
    Left = 240
    ParamData = <
      item
        Name = 'Customer'
      end
      item
        Name = 'Branch_No'
      end
      item
        Name = 'Rep'
      end
      item
        Name = 'Percentage'
      end
      item
        Name = 'Is_Main_Rep'
        DataType = ftString
      end>
  end
