  object GetRepsSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Select Rep, Name'
      'From Rep'
      'where'
      '((Rep.Rep = :Rep) or (:Rep = 0)) and'
      
        '((Rep.Inactive = '#39'N'#39') or (Rep.Inactive = :Inactive) or (Rep.Inac' +
        'tive is NULL))'
      'Order By Name')
    Left = 40
    Top = 4
    ParamData = <
      item
        Name = 'Rep'
      end
      item
        Name = 'Rep'
      end
      item
        Name = 'Inactive'
      end>
  end
  object RepsSRC: TDataSource
    DataSet = GetRepsSQL
    Left = 88
    Top = 4
  end
