  object qryBranches: TFDQuery
    ConnectionName = 'pb'
    SQL.Strings = (
      'select *'
      'from Customer_branch'
      'where Customer = :Customer and'
      
        '((Customer_branch.Inactive = '#39'N'#39') or (Customer_branch.Inactive =' +
        ' :Inactive) or (Customer_branch.Inactive is NULL))'
      'order by Name')
    Left = 168
    Top = 4
    ParamData = <
      item
        Name = 'Customer'
      end
      item
        Name = 'Inactive'
      end>
  end
