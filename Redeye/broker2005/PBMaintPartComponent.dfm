  object qryGetLastNo: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'select Max(Element_No) as Last_no'
      'from Part_Element'
      'where Part = :Part')
    Left = 32
    Top = 8
    ParamData = <
      item
        Name = 'Part'
      end>
  end
  object qryDel: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
