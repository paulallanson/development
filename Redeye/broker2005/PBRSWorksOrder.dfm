  object qryUpWOStatus: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Update Works_Order'
      'set Works_Order_Status = 30'
      'where Works_Order = :Works_Order')
    Left = 24
    Top = 45
    ParamData = <
      item
        Name = 'Works_Order'
      end>
  end
