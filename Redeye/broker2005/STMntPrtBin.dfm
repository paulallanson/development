  object DelBinSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Delete From Part_Store_Bin'
      'Where (Part_Store = :Part_Store) and'
      '      (Part_Bin = :Part_Bin)'
      ' ')
    Left = 128
    Top = 96
    ParamData = <
      item
        DataType = ftUnknown
        Name = 'Part_Store'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'Part_Bin'
        ParamType = ptUnknown
      end>
  end
  object UpdBinSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Update Part_Store_Bin'
      'Set'
      'Bin_Can_Pick = :Bin_Can_Pick'
      'Where (Part_Store = :Part_Store) and'
      '      (Part_Bin = :Part_Bin)'
      ' '
      ' ')
    Left = 136
    Top = 56
    ParamData = <
      item
        DataType = ftUnknown
        Name = 'Bin_Can_Pick'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'Part_Store'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'Part_Bin'
        ParamType = ptUnknown
      end>
  end
