  object UpdSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Update Part_Customer'
      'Set Customer_Part_Code = :Customer_Part_Code,'
      'Sell_Price = :Sell_Price,'
      'Sell_Pack_Quantity = :Sell_Pack_Quantity'
      'Where'
      '(Part = :Part) and'
