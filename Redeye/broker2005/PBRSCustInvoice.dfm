  object qryGetSalesOrders: TQuery
    DatabaseName = 'PB'
    SQL.Strings = (
      'SELECT  Sales_Order.Sales_Order,'
      '        Sales_Order.Date_Required,'
      '        Sales_Order.Date_Ordered,'
      '        Sales_Order.Customer,'
      '        Sales_Order.Sales_order_Head_Status,'
      '        Sales_Order_line.Sales_Order_line_no,'
      '        Sales_Order_line.Part,'
      '        Sales_Order_line.Part_Cost,'
      '        Sales_Order_line.Purch_Pack_Quantity,'
      '        Sales_Order_line.Part_Sales_Price,'
      '        Sales_Order_line.Sell_Pack_Quantity,'
      '        Sales_Order_line.Quantity_Delivered,'
      '        Sales_Order_line.vat_code,'
      '        Sales_Order_line.Discount_Type,'
      '        Sales_Order_line.Discount_value,'
      '        (select Sales_OrderRep.Rep'
      '         from Sales_OrderRep'
      
        '         where Sales_OrderRep.Sales_Order = Sales_Order.Sales_Or' +
        'der) AS Rep,'
      '        Part.price_unit,'
      '        Part.Product_Type,'
      '        Part.Sales_nominal,'
      '        Vat_Code.VAT_Rate'
      'FROM (Part'
      '      INNER JOIN (Sales_Order'
      '      INNER JOIN Sales_Order_line'
      
        '        ON Sales_Order.Sales_Order = Sales_Order_line.Sales_Orde' +
        'r)'
      '        ON Part.Part = Sales_Order_line.Part)'
      '      LEFT JOIN Vat_Code'
      '        ON Sales_Order_line.vat_code = Vat_Code.Vat_Code'
      'WHERE'
      '  Sales_Order.Customer = :Customer and'
      '  ('
      '  (Sales_Order.Date_Required >= :Date_From and'
      #9'Sales_Order.Date_Required <= :Date_To)'
      '  ) and'
      '  (Sales_Order.Sales_Order_Head_Status >= 140) AND'
      '  (Sales_Order.Sales_Order_Head_Status < 250)'
      
        'ORDER BY Sales_Order_Line.Sales_Order, Sales_Order_Line.Sales_Or' +
        'der_line_no')
    Left = 40
    Top = 48
    ParamData = <
      item
        DataType = ftUnknown
        Name = 'Customer'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'Date_From'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'Date_To'
        ParamType = ptUnknown
      end>
  end
end
