  object DetsSRC: TDataSource
    DataSet = GetDetsSQL
    Left = 136
    Top = 24
  end
  object GetDetsSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Select  Product_Type.Product_Type,'
      '        Product_Type.Description,'
      '        Product_Type.Short_Desc,'
      '        Product_Type.Nominal,'
      '        Product_Type.Purchase_Nominal,'
      '        Product_Type.Category,'
      '        Product_Type.Narrative,'
      '        Category.Description as Category_Description,'
      '        Product_Type.inactive,'
      '        Product_type.Enquiry_Min_Suppliers,'
      '        FSC_Product_Type_Code,'
      '        (select Price_Unit.Description'
      '         from Price_unit'
      
        '         where Price_Unit.Price_unit = Product_Type.Default_Pric' +
        'e_Unit) as Default_Price_unit'
      'From Product_Type, Category'
      'Where (Product_Type.Description Like :Code_From) and'
      '((Product_Type.Category = :Category) or (:Category = 0)) and'
      'Product_Type.Category = Category.Category and'
      
        '((Product_Type.Inactive = '#39'N'#39') or (Product_Type.Inactive is NULL' +
        ') or (Product_Type.Inactive = :Inactive))'
      'Order By Product_Type.Description'
      ' ')
    Left = 24
    Top = 24
    ParamData = <
      item
        Name = 'Code_From'
      end
      item
        Name = 'Category'
      end
      item
        Name = 'Category'
      end
      item
        Name = 'Inactive'
      end>
  end
