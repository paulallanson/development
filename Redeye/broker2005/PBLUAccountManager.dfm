  object DetsSRC: TDataSource
    DataSet = GetDetsSQL
    Left = 136
    Top = 24
  end
  object GetDetsSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Select User_Group_Operator.User_Group_Operator,'
      '        Operator.Operator,'
      '        Operator.Name,'
      '        (select Account_Team.Account_Team'
      '        from Account_Team_Member, Account_Team'
      
        '        where Account_Team_member.Operator = User_Group_Operator' +
        '.Operator and'
      
        '              Account_team_member.Account_Team = Account_Team.Ac' +
        'count_Team) as Account_Team,'
      '        (select Account_Team_Name'
      '        from Account_Team_Member, Account_Team'
      
        '        where Account_Team_member.Operator = User_Group_Operator' +
        '.Operator and'
      
        '              Account_team_member.Account_Team = Account_Team.Ac' +
        'count_Team) as Account_Team_Name'
      'From User_Group_Operator, Operator'
      'Where (Operator.Name Like :Code_From) and'
      'User_Group_Operator.Operator = Operator.Operator and'
      'User_Group = 4'
      'Order By Operator.Name')
    Left = 64
    Top = 64
    ParamData = <
      item
        Name = 'Code_From'
      end>
  end
