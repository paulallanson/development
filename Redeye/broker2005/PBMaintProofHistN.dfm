        Name = 'Proof_History'
      end>
  end
  object StatSRC: TDataSource
    DataSet = GetStatSQL
    Left = 192
    Top = 12
  end
  object GetStatSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Select Description, Proof_Status'
      'From Proof_Status'
      'WHERE ((inactive = '#39'N'#39') or (inactive is NULL)) OR'
      '(Proof_Status = :Proof_Status)'
      'Order By Proof_Status')
    Left = 32
    Top = 88
    ParamData = <
      item
        DataType = ftUnknown
        Name = 'Proof_Status'
        ParamType = ptUnknown
      end>
  end
