  object GetCustNameSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Select Customer.Name as Cust_Name,'
      '       Customer_Branch.Name as Branch_Name'
      'From  Customer, Customer_Branch'
      'Where (Customer.Customer = :Customer) and'
      '      (Customer_Branch.Customer = :Customer) and'
      '      (Customer_Branch.Branch_No = :Branch)')
    Left = 224
    Top = 229
    ParamData = <
      item
        Name = 'Customer'
      end
      item
        Name = 'Customer'
      end
      item
        Name = 'Branch'
      end>
  end
  object qryPartsOnSOs: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'select sales_order_line.part, '
      ' part.part_description,'
      ' part_group.part_group_descr_short,'
      ' part.part_purchase_price,'
      ' part.part_cost_cat '
      'from ((sales_order_line inner join '
      
        ' sales_order on sales_order_line.sales_order = sales_order.sales' +
        '_order) inner join '
      ' part on sales_order_line.part = part.part) left join '
      ' part_group on part.part_group = part_group.part_group'
      'where sales_order.customer = :cust and '
      ' sales_order.date_ordered >= :dateFrom')
    Left = 56
    Top = 253
    ParamData = <
      item
        Name = 'cust'
      end
      item
        Name = 'dateFrom'
      end>
  end
end
