  object GetODueEnqDetsSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'SELECT DISTINCT '#9'Supplier.Name,'
      #9#9#9#9#9#9#9'Supplier.Supplier,'
      '                    Supplier_Branch.Narrative,'
      '        Supplier_Branch.Phone,'
      
        '        Supplier_Branch.Fax_Number, Supplier_Branch.Branch_No, S' +
        'upplier_Branch.Name as Branch_Name'
      'FROM Supplier, EnquiryLine, Supplier_Enquiry, Supplier_Branch'
      'WHERE (EnquiryLine.Req_Response_Date < :ODue_Date ) AND'
      '      (Supplier_Enquiry.Act_Response_Date IS Null) AND'
      '      (EnquiryLine.Line = Supplier_Enquiry.Line) AND'
      '      (EnquiryLine.Enquiry = Supplier_Enquiry.Enquiry) AND'
      '      (Supplier.Supplier = Supplier_Enquiry.Supplier) AND'
      '      ('
      '      (Supplier_Branch.Supplier = Supplier.Supplier) AND'
      '      (Supplier_Branch.Branch_No = 0)'
      '      ) AND Supplier.Name Like :Code_From'
      'Order By Supplier.Name'
      ' ')
    Left = 136
    Top = 112
    ParamData = <
      item
        Name = 'ODue_Date'
        DataType = ftDateTime
      end
      item
        Name = 'Code_From'
      end>
  end
end
