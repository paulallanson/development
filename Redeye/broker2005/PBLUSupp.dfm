  object GetDetsSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Select  Supplier.Supplier,'
      '        Supplier.Name, Supplier_Branch.Narrative,'
      '        Supplier_Branch.Phone,'
      
        '        Supplier_Branch.Fax_Number, Supplier_Branch.Branch_No, S' +
        'upplier_Branch.Name as Branch_Name,'
      '        Supplier.Courier'
      'From Supplier, Supplier_Branch'
      'Where '
      '      ('
      '      (Supplier.Name Like :Code_From) or'
      '      (Supplier_Branch.Account_Code Like :Code_From)'
      '      ) and'
      '      (Supplier_Branch.Supplier = Supplier.Supplier) and'
      '      (Supplier_Branch.Branch_No = 0) and'
      '      ((Acc_Active = '#39'Y'#39') or (:Active_Only = Acc_Active))'
      'Order By Supplier.Name'
      ' ')
    Left = 104
    Top = 40
    ParamData = <
      item
        Name = 'Code_From'
      end
      item
        Name = 'Code_From'
      end
      item
        Name = 'Active_Only'
      end>
  end
