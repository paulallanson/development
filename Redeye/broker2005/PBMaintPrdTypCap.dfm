  object qryCheckPTCapExists: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'SELECT Description'
      'FROM Product_TypeCapability'
      'WHERE Product_Type = :Product_Type AND'
      '      Description = :Description AND'
      '      ((Capability <> :Capability) OR (:Capability = 0))')
    Left = 96
