  object AddSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Insert Into Product_TypeCapability'
      '        (Product_Type,'
      '        Capability,'
      '        Description)'
      'Select :Product_Type, Max(Capability)+1, :GUID'
      'From Product_TypeCapability'
      'Where Product_Type = :Product_Type')
