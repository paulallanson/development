  object qryGetSuppliers: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'select Splr_BrnchPrdct_TypCpblty.Supplier,'
      '        Splr_BrnchPrdct_TypCpblty.Branch_no'
      'from Splr_BrnchPrdct_TypCpblty, Product_TypeCapability'
      
        'where Splr_BrnchPrdct_TypCpblty.Product_type = Product_TypeCapab' +
        'ility.Product_Type AND'
      
        #9#9'Splr_BrnchPrdct_TypCpblty.Capability = Product_TypeCapability.' +
        'Capability AND'
      #9#9'Product_TypeCapability.Product_Type <> :Product_Type and'
      #9#9'Product_TypeCapability.description = :Description and'
      
        #9#9'((Product_TypeCapability.Default_for_all = '#39'N'#39') or (Product_Ty' +
        'peCapability.Default_for_all is NULL))')
    Left = 208
    Top = 96
    ParamData = <
