  object GetLastSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Select Max(VAT_Code) as Last_Code'
      'From VAT_Code ')
    Left = 192
    Top = 24
  end
  object AddSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Insert Into VAT_Code'
      
        '(VAT_Code, VAT_Rate, Description, VAT_Ref, Sales_Ledger_Descript' +
        'ion, Purchase_Ledger_Description)'
      'Values'
      
        '(:VAT_Code, :VAT_Rate, :Description, :VAT_Ref, :Sales_Ledger_Des' +
        'cription, :Purchase_Ledger_Description)'
      '')
    Left = 320
    Top = 64
    ParamData = <
      item
        Name = 'VAT_Code'
      end
      item
        Name = 'VAT_Rate'
      end
      item
        Name = 'Description'
      end
      item
        Name = 'VAT_Ref'
      end
      item
        Name = 'Sales_Ledger_Description'
      end
      item
        Name = 'Purchase_Ledger_Description'
      end>
  end
  object UpdSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Update VAT_Code'
      'Set'
      'Description = :Description,'
      'VAT_Rate = :VAT_Rate,'
      'VAT_Ref = :VAT_Ref,'
      'Sales_Ledger_Description = :Sales_Ledger_Description,'
      'Purchase_Ledger_Description = :Purchase_Ledger_Description'
      'Where VAT_Code = :VAT_Code')
    Left = 144
    Top = 16
    ParamData = <
      item
        Name = 'Description'
      end
      item
        Name = 'VAT_Rate'
      end
      item
        Name = 'VAT_Ref'
      end
      item
        Name = 'Sales_Ledger_Description'
      end
      item
        Name = 'Purchase_Ledger_Description'
      end
      item
        Name = 'VAT_Code'
      end>
  end
  object DelSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Delete From VAT_Code'
      'Where'
      '(VAT_Code = :VAT_Code)')
    Left = 240
    Top = 16
    ParamData = <
      item
        Name = 'VAT_Code'
      end>
  end
  object DetsSRC: TDataSource
    DataSet = AddSQL
    Left = 320
    Top = 16
  end
  object CheckUniqueRefSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Select VAT_Code'
      'From VAT_Code'
      'Where (VAT_Code <> :VAT_Code) and'
      '      (VAT_Ref = :VAT_Ref)')
    Left = 232
    Top = 64
    ParamData = <
      item
        Name = 'VAT_Code'
      end
      item
        Name = 'VAT_Ref'
      end>
  end
end
