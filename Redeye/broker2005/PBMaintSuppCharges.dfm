  object qryGetNextCharge: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'select max(Charge_no) as Last_Charge'
      'from Supplier_Charge'
      'where Supplier = :Supplier')
    Left = 40
    Top = 20
    ParamData = <
      item
        Name = 'Supplier'
      end>
  end
  object qryAddCharge: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'insert into Supplier_Charge'
      '('
      'Supplier,'
      'Charge_no,'
      'Details,'
      'Amount,'
      'Quotation_Price,'
      'Vat_Code)'
      'values'
      '('
      ':Supplier,'
      ':Charge_no,'
      ':Details,'
      ':Amount,'
      ':Quotation_Price,'
      ':Vat_Code)')
    Left = 128
    Top = 20
    ParamData = <
      item
        Name = 'Supplier'
      end
      item
        Name = 'Charge_no'
      end
      item
        Name = 'Details'
      end
      item
        Name = 'Amount'
      end
      item
        Name = 'Quotation_Price'
      end
      item
        Name = 'Vat_Code'
      end>
  end
  object qryUpdCharge: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Update Supplier_Charge'
      'Set Details = :Details,'
      'Amount = :Amount,'
      'Quotation_Price = :Quotation_Price,'
      'Vat_Code = :Vat_Code'
      'Where Supplier = :Supplier AND'
      'Charge_no = :Charge_No')
    Left = 192
    Top = 20
    ParamData = <
      item
        Name = 'Details'
      end
      item
        Name = 'Amount'
      end
      item
        Name = 'Quotation_Price'
      end
      item
        Name = 'Vat_Code'
      end
      item
        Name = 'Supplier'
      end
      item
        Name = 'Charge_No'
      end>
  end
  object qryVatCode: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'select * from Vat_Code'
      'order By Vat_Rate')
    Left = 304
    Top = 20
  end
  object dtsVatCode: TDataSource
    DataSet = qryVatCode
    Left = 344
    Top = 20
  end
  object qryDelCharge: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Delete from Supplier_Charge'
      'where Supplier = :Supplier and Charge_no = :Charge_no')
    Left = 40
    Top = 76
    ParamData = <
      item
        Name = 'Supplier'
      end
      item
        Name = 'Charge_no'
      end>
