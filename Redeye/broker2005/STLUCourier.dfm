  object DetsSRC: TDataSource
    DataSet = GetDetsSQL
    Left = 120
    Top = 72
  end
  object GetDetsSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Select *'
      'from Courier'
      'where courier_name like :Code_From and'
      
        '((Inactive = '#39'N'#39') or (Inactive is NULL) or (Inactive = :Inactive' +
        '))'
      'order by Courier_name')
    Left = 32
    Top = 48
    ParamData = <
      item
        Name = 'Code_From'
      end
      item
        Name = 'Inactive'
      end>
  end
  object SearchTimer: TTimer
    Enabled = False
