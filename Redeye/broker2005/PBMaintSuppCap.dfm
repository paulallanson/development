  object GetLastIntSelSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Select max(Int_Sel_Code) as Last_Code from Int_Sel')
    Left = 128
    Top = 96
  end
  object AddIntSelSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Insert Into Int_Sel'
      '(Int_Sel_Code, Sel1, Sel2, Sel3, Sel4)'
      'Values'
      '(:Int_Sel_Code, :Sel1, :Sel2, :Sel3, :Sel4)'
      ' ')
    Left = 120
    Top = 256
    ParamData = <
      item
        DataType = ftInteger
        Name = 'Int_Sel_Code'
        ParamType = ptUnknown
      end
      item
        DataType = ftInteger
        Name = 'Sel1'
        ParamType = ptUnknown
      end
      item
        DataType = ftInteger
        Name = 'Sel2'
        ParamType = ptUnknown
      end
      item
        DataType = ftInteger
        Name = 'Sel3'
        ParamType = ptUnknown
      end
      item
        DataType = ftInteger
        Name = 'Sel4'
        ParamType = ptUnknown
      end>
  end
  object DelIntSelsSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Delete From Int_Sel'
      'Where (Int_Sel_Code = :Int_Sel_Code) and'
      '      ((Sel1 = :Sel1) or (:Sel1 = 0))'
      ' ')
    Left = 48
    Top = 144
    ParamData = <
      item
        DataType = ftInteger
        Name = 'Int_Sel_Code'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'Sel1'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'Sel1'
        ParamType = ptUnknown
      end>
  end
  object LoadIntSelSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Insert Into Int_Sel'
      '(Int_Sel_Code, Sel1, Sel2, Sel3, Sel4, Text100)'
      'Select :Int_Sel_Code, Splr_BrnchPrdct_TypCpblty.Product_Type,'
      
        '        Splr_BrnchPrdct_TypCpblty.Capability, 0, 0, Product_Type' +
        'Capability.Default_For_All'
      'From Splr_BrnchPrdct_TypCpblty, Product_TypeCapability'
      'Where (Splr_BrnchPrdct_TypCpblty.Supplier = :Supplier) and'
      '      (Splr_BrnchPrdct_TypCpblty.Branch_No = :Branch_No) and'
      
        '      (Product_TypeCapability.Product_Type = Splr_BrnchPrdct_Typ' +
        'Cpblty.Product_Type) and'
      
        '      (Product_TypeCapability.Capability = Splr_BrnchPrdct_TypCp' +
        'blty.Capability) AND'
      
        '      ((Product_TypeCapability.InActive = '#39'N'#39') OR (Product_TypeC' +
        'apability.InActive IS NULL))')
    Left = 88
    Top = 320
    ParamData = <
      item
        DataType = ftInteger
        Name = 'Int_Sel_Code'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'Supplier'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'Branch_No'
        ParamType = ptUnknown
      end>
  end
  object GetIntSelSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Select Int_Sel.Sel1 as Product_Type, Int_Sel.Sel2 as Capability,'
      '       Product_Type.Description as PT_Description,'
      '       Product_TypeCapability.Description as Cap_Description,'
      '       Int_Sel.Text100'
      'From Int_Sel, Product_Type, Product_TypeCapability'
      'Where (Int_Sel_Code = :Int_Sel_Code) and'
      '      (Int_Sel.Sel1 <> 0) and'
      '      (Product_Type.Product_Type = Int_Sel.Sel1) and'
      '      (Product_TypeCapability.Product_Type = Int_Sel.Sel1) and'
      '      (Product_TypeCapability.Capability = Int_Sel.Sel2) AND'
      
        '      ((Product_TypeCapability.InActive = '#39'N'#39') OR (Product_TypeC' +
        'apability.InActive IS NULL))'
      
        'Order By Product_Type.Description, Product_TypeCapability.Descri' +
        'ption'
      ' '
      ' '
      ' ')
    Left = 40
    Top = 288
    ParamData = <
      item
        DataType = ftInteger
        Name = 'Int_Sel_Code'
        ParamType = ptUnknown
      end>
  end
  object GetUnSelProdTypsSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Select Product_Type.Product_Type,'
      '       Product_Type.Description,'
      '       Product_TypeCapability.Capability,'
      '       Product_TypeCapability.Description as Cap_Description'
      'From Product_Type, Product_TypeCapability'
      
        'Where   (Product_TypeCapability.Product_Type = Product_Type.Prod' +
        'uct_Type) and'
      '        (Product_TypeCapability.Default_For_All = '#39'Y'#39')  AND'
      
        '        ((Product_TypeCapability.InActive = '#39'N'#39') OR (Product_Typ' +
        'eCapability.InActive IS NULL)) and'
      '        (Product_Type.Product_Type not in (Select Sel1'
      '                                        From Int_Sel'
      
        '                                        Where (Int_Sel_Code = :I' +
        'nt_Sel_Code) and'
      
        '                                               (Int_Sel.Sel1 =  ' +
        'Product_Type.Product_Type)))'
      'Order By Product_Type.Description'
      ' '
      ' ')
    Left = 352
    Top = 64
    ParamData = <
      item
        DataType = ftInteger
        Name = 'Int_Sel_Code'
        ParamType = ptUnknown
      end>
  end
  object UnSelProdTypsDS: TDataSource
    DataSet = GetUnSelProdTypsSQL
    Left = 353
    Top = 128
  end
  object GetUnSelCapsSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Select Product_TypeCapability.Capability,'
      '       Product_TypeCapability.Description as Cap_Description'
      'From Product_TypeCapability'
      
        'Where   (Product_TypeCapability.Product_Type = :Product_Type) an' +
        'd'
      '        ((Product_TypeCapability.Default_For_All <> '#39'Y'#39') or'
      '         (Product_TypeCapability.Default_For_All = Null)) and'
      
        '        ((Product_TypeCapability.inactive = '#39'N'#39') OR (Product_Typ' +
        'eCapability.inactive IS NULL)) AND'
      '        (Product_TypeCapability.Capability not in (Select Sel2'
      '                                        From Int_Sel'
      
        '                                        Where (Int_Sel_Code = :I' +
        'nt_Sel_Code) and'
      
        '                                               (Int_Sel.Sel1 =  ' +
        'Product_TypeCapability.Product_Type) and'
      
        '                                               (Int_Sel.Sel2 = P' +
        'roduct_TypeCapability.Capability)))'
      'Order By Product_TypeCapability.Description'
      ' '
      ' '
      ' '
      ' '
      ' ')
    Left = 288
    Top = 304
    ParamData = <
      item
        DataType = ftInteger
        Name = 'Product_Type'
        ParamType = ptUnknown
      end
      item
        DataType = ftInteger
        Name = 'Int_Sel_Code'
        ParamType = ptUnknown
      end>
  end
  object UnSelCapsDS: TDataSource
    DataSet = GetUnSelCapsSQL
    Left = 321
    Top = 384
  end
  object DelIntSelSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Delete From Int_Sel'
      'Where (Int_Sel_Code = :Int_Sel_Code) and'
      '      (Sel1 = :Sel1) and'
      '      (Sel2 = :Sel2)'
      ' ')
    Left = 96
    Top = 144
    ParamData = <
      item
        DataType = ftInteger
        Name = 'Int_Sel_Code'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'Sel1'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'Sel2'
        ParamType = ptUnknown
      end>
  end
  object GetDefCapSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Select Product_TypeCapability.Capability,'
      '       Product_TypeCapability.Description'
      'From Product_TypeCapability'
      'Where (Product_TypeCapability.Product_Type = :Product_Type) and'
      '      (Product_TypeCapability.Default_For_All = '#39'Y'#39') AND'
      
        '      ((Product_TypeCapability.inactive = '#39'N'#39') OR (Product_TypeC' +
        'apability.inactive IS NULL))'
      ''
      ' '
      ' '
      ' ')
    Left = 384
    Top = 304
    ParamData = <
      item
        DataType = ftInteger
        Name = 'Product_Type'
        ParamType = ptUnknown
      end>
  end
