  object qryAdd: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'insert into Part_Quantity_Price'
      '  (Part,'
      '  Quantity,'
      '  Sell_Price,'
      '  Cost_Price,'
      '  Sell_Pack_Quantity,'
      '  Purch_Pack_Quantity,'
      '  Supplier,'
      '  Sell_Unit,'
      '  Cost_Unit)'
      'values'
      '  (:Part,'
      '  :Quantity,'
      '  :Sell_Price,'
      '  :Cost_Price,'
      '  :Sell_Pack_Quantity,'
      '  :Purch_Pack_Quantity,'
      '  :Supplier,'
      '  :Sell_Unit,'
      '  :Cost_Unit)')
    Left = 440
    Top = 112
    ParamData = <
      item
        Name = 'Part'
      end
      item
        Name = 'Quantity'
      end
      item
        Name = 'Sell_Price'
      end
      item
        Name = 'Cost_Price'
      end
      item
        Name = 'Sell_Pack_Quantity'
      end
      item
        Name = 'Purch_Pack_Quantity'
      end
      item
        Name = 'Supplier'
      end
      item
        Name = 'Sell_Unit'
      end
      item
        Name = 'Cost_Unit'
      end>
  end
  object qryCostUnit: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'select *'
      'from price_unit'
      
        'where ((price_unit_inactive = '#39'N'#39') or (price_unit_inactive is NU' +
        'LL))'
      'order by Description')
    Left = 312
    Top = 304
  end
