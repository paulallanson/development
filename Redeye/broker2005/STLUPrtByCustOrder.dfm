  object qryPartsOnSOs: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'select distinct(sales_order_line.part),'
      ' part.part_description,'
      ' part_group.part_group_descr_short,'
      ' part.part_purchase_price,'
      ' part.part_cost_cat'
      'from ((sales_order_line inner join'
      
        ' sales_order on sales_order_line.sales_order = sales_order.sales' +
        '_order) inner join'
      ' part on sales_order_line.part = part.part) left join'
      ' part_group on part.part_group = part_group.part_group'
      'where sales_order.customer = :cust and'
      ' sales_order.date_ordered >= :dateFrom'
      ' '
      ' ')
    Left = 32
    Top = 85
    ParamData = <
      item
        Name = 'cust'
        DataType = ftInteger
        ParamType = ptInput
        Value = 0
      end
      item
        Name = 'dateFrom'
        DataType = ftDate
        ParamType = ptInput
        Value = 0d
      end>
  end
  object qryPartsOnSOsFiltered: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'select distinct(sales_order_line.part),'
      ' part.part_description,'
      ' part_group.part_group_descr_short,'
      ' part.part_purchase_price,'
      ' part.part_cost_cat'
      'from ((sales_order_line inner join'
      
        ' sales_order on sales_order_line.sales_order = sales_order.sales' +
        '_order) inner join'
      ' part on sales_order_line.part = part.part) left join'
      ' part_group on part.part_group = part_group.part_group'
      'where sales_order.customer = :cust and'
      ' sales_order.date_ordered >= :dateFrom and'
      ' sales_order_line.part like :part and'
      ' part.part_description like :partDesc;'
      ' '
      ' ')
    Left = 32
    Top = 141
    ParamData = <
      item
        Name = 'cust'
      end
      item
        Name = 'dateFrom'
      end
      item
        Name = 'part'
      end
      item
        Name = 'partDesc'
      end>
  end
end
