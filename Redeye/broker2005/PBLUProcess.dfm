  object DetsSRC: TDataSource
    DataSet = GetDetsSQL
    Left = 136
    Top = 24
  end
  object GetDetsSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'SELECT  Process.Process,'
      '        Process.Process_Description,'
      '        Process.Allow_multiple_elements,'
      '        Process.Nominal,'
      '        Process.Price_unit,'
      '        Process.Email,'
      '        Process.cc_Email,'
      '        Price_Unit.Description as Price_Unit_Description,'
      '        Process.Product_Type,'
      '        Product_Type.Description as Product_Type_Description,'
      '        Product_Type.Category,'
      '        Process.Short_Desc,'
      '        Process.Process_Group,'
      '        Process.Use_as_Default,'
      '        Process.Inactive,'
      '        Process.Prompt_For_Laser_Format,'
      '        Process.Prompt_For_Paper_Size,'
      '        Process.Number_Type,'
      '        Process.Paper_Prompt_Narrative,'
      '        Process.Short_Description,'
      '        Process.SFDC_Prompt_For_Laser_Format,'
      '        Process.SFDC_Prompt_For_Paper_Size,'
      '        Process.SFDC_Prompt_For_Number_Up'
      'FROM Product_Type'
      '      RIGHT JOIN (Price_Unit'
      
        '      RIGHT JOIN Process ON Price_Unit.Price_Unit = Process.Pric' +
        'e_unit)'
      '        ON Product_Type.Product_Type = Process.Product_Type'
      'WHERE Process_description like :Code_From and'
      
        '((Process.Inactive = '#39'N'#39') or (Process.Inactive is NULL) or (Proc' +
        'ess.Inactive = :Inactive)) and'
      '((Process_Group = :Process_Group) or (:Process_Group = 0))'
      'ORDER BY Process.Process_Description'
      ' ')
    Left = 24
    Top = 24
    ParamData = <
      item
        Name = 'Code_From'
      end
      item
        Name = 'Inactive'
      end
      item
        Name = 'Process_Group'
      end
      item
        Name = 'Process_Group'
      end>
  end
