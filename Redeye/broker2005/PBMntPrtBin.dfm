  object GetBinsSQL: TQuery
    DatabaseName = 'PB'
    SQL.Strings = (
      'Select Part_Store_Bin.Part_Bin, Part_Store_Bin.Bin_Can_Pick,'
      '       (Select Sum(Store_Quantity)'
      '               From Store_Stock'
      '               Where (Store_Stock.Part_Store = :Part_Store) and'
      
        '                     (Store_Stock.Part_Bin = Part_Store_Bin.Part' +
        '_Bin)) as Bin_Qty'
      'from Part_Store_bin'
      'Where (Part_Store = :Part_Store)'
      'Order By Part_Bin'
      ' ')
    Left = 192
    Top = 56
    ParamData = <
      item
        DataType = ftUnknown
        Name = 'Part_Store'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'Part_Store'
        ParamType = ptUnknown
      end>
  end
