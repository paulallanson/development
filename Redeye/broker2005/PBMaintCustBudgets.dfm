  object qryCustomer: TQuery
    DatabaseName = 'PB'
    SQL.Strings = (
      
        'SELECT Customer.Customer, Customer.Name as Customer_Name, Custom' +
        'er_Budget.Period, Customer_Budget.Profit_Value, Customer_Budget.' +
        'Turnover_Value'
      
        'FROM Customer LEFT JOIN Customer_Budget ON Customer.Customer = C' +
        'ustomer_Budget.Customer'
      
        'WHERE ((acc_active = '#39'Y'#39') or (acc_active = null)) and (((Period ' +
        '>= :Start_Period) and (Period <= :End_Period)) or (Period is NUL' +
        'L))'
      'ORDER BY Customer.Name')
    Left = 472
    Top = 152
    ParamData = <
      item
        DataType = ftUnknown
        Name = 'Start_Period'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'End_Period'
        ParamType = ptUnknown
      end>
  end
  object qryPeriods: TQuery
    DatabaseName = 'PB'
    SQL.Strings = (
      'select Period, Description, Financial_Year'
      'from Period'
      'where Financial_Year = :Financial_Year'
      'ORDER BY Period')
    Left = 568
    Top = 152
    ParamData = <
      item
        DataType = ftUnknown
        Name = 'Financial_Year'
        ParamType = ptUnknown
      end>
  end
  object qryDel: TQuery
    DatabaseName = 'PB'
    SQL.Strings = (
      'delete from Customer_Budget'
      'where Period >= :Start_Period and Period <= :End_Period')
    Left = 480
    Top = 216
    ParamData = <
      item
        DataType = ftUnknown
        Name = 'Start_Period'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'End_Period'
        ParamType = ptUnknown
      end>
  end
  object qryAdd: TQuery
    DatabaseName = 'PB'
    SQL.Strings = (
      'insert into Customer_Budget'
      '  (Customer,'
      '  Period,'
      '  Turnover_Value,'
      '  Profit_Value)'
      'values'
      '  (:Customer,'
      '  :Period,'
      '  :Turnover_Value,'
      '  :Profit_Value)'
      '')
    Left = 568
    Top = 216
    ParamData = <
      item
        DataType = ftUnknown
        Name = 'Customer'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'Period'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'Turnover_Value'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'Profit_Value'
        ParamType = ptUnknown
      end>
  end
