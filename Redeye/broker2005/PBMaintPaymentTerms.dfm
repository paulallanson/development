  object UpdSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Update Payment_Terms'
      
        'Set     Payment_Terms_Description = :Payment_Terms_Description, ' +
        'Payment_Type = :Payment_Type, Number_of_Days = :Number_of_Days'
      'Where'
      '(Payment_Terms = :Payment_Terms) '
      '')
    Left = 16
    Top = 112
    ParamData = <
      item
        Name = 'Payment_Terms_Description'
      end
      item
        Name = 'Payment_Type'
      end
      item
        Name = 'Number_of_Days'
      end
      item
        Name = 'Payment_Terms'
      end>
  end
