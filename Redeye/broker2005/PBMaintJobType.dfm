  object qryInsJobType: TQuery
    DatabaseName = 'PB'
    SQL.Strings = (
      'Insert into job_type'
      '  (job_type,'
      '  Job_Type_Description,'
      '  One_Delivery_only,'
      '  Can_Deliver_to_Stock,'
      '  Rep_Can_Convert_Enquiry)'
      'values'
      '  (:job_type,'
      '  :Job_Type_Description,'
      '  :One_Delivery_only,'
      '  :Can_Deliver_to_Stock,'
      '  :Rep_Can_Convert_Enquiry);'
      ' '
      ' '
      ' '
      ' ')
    Left = 264
    Top = 16
    ParamData = <
      item
        DataType = ftUnknown
        Name = 'job_type'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'Job_Type_Description'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'One_Delivery_only'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'Can_Deliver_to_Stock'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'Rep_Can_Convert_Enquiry'
        ParamType = ptUnknown
      end>
  end
  object qryUpdJobType: TQuery
    DatabaseName = 'PB'
    SQL.Strings = (
      'Update job_type'
      'set Job_Type_Description = :Job_Type_Description,'
      '    One_Delivery_only = :One_Delivery_only,'
      '    Can_Deliver_to_Stock = :Can_Deliver_to_Stock,'
      '    Rep_Can_Convert_Enquiry = :Rep_Can_Convert_Enquiry'
      'where job_type = :job_type;'
      ' '
      ' ')
    Left = 296
    Top = 16
    ParamData = <
      item
        DataType = ftUnknown
        Name = 'Job_Type_Description'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'One_Delivery_only'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'Can_Deliver_to_Stock'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'Rep_Can_Convert_Enquiry'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'job_type'
        ParamType = ptUnknown
      end>
  end
  object qryDelJobType: TQuery
    DatabaseName = 'PB'
    SQL.Strings = (
      'delete from job_type'
      'where job_type = :job_type;'
      ' ')
    Left = 328
    Top = 16
    ParamData = <
      item
        DataType = ftUnknown
        Name = 'job_type'
        ParamType = ptUnknown
      end>
  end
  object qrySelNextJobType: TQuery
    DatabaseName = 'PB'
    SQL.Strings = (
      'Select Max(job_type) as last_job_type_no from job_type;')
    Left = 232
    Top = 16
  end
end
