  object DetsSRC: TDataSource
    DataSet = GetDetsSQL
    Left = 136
    Top = 24
  end
  object GetDetsSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Select  Product_TypeQuestion.Question,'
      '        Product_TypeQuestion.Question_Text, '
      '        Product_TypeQuestion.Sequence_Reference,'
      '        Product_TypeQuestion.Prompt_type, '
      '        Product_TypeQuestion.Question_Category,'
      '        Product_TypeQuestion.inactive'
      'From Product_TypeQuestion'
      'Where (Product_TypeQuestion.Question_Text Like :Code_From) and'
      '      (Product_TypeQuestion.Product_Type = :Product_Type) and'
      
        '      ((Product_TypeQuestion.inactive = '#39'N'#39') or (Product_TypeQue' +
        'stion.inactive is NULL) or (Product_TypeQuestion.inactive = :Ina' +
        'ctive))'
      'Order By Product_TypeQuestion.Sequence_Reference')
    Left = 24
    Top = 24
    ParamData = <
      item
        Name = 'Code_From'
        DataType = ftString
      end
      item
        Name = 'Product_Type'
        DataType = ftInteger
      end
      item
        Name = 'Inactive'
      end>
  end
  object SearchTimer: TTimer
    Enabled = False
