  object AddSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Insert Into Product_TypeQuestion'
      '        (Product_Type,'
      '        Question,'
      '        Question_Text)'
      'Select :Product_Type, Max(Question)+1, :GUID'
      'From Product_TypeQuestion'
      'Where Product_Type = :Product_Type'
      '')
    Left = 168
    Top = 24
    ParamData = <
      item
        Name = 'Product_Type'
        DataType = ftInteger
        ParamType = ptInput
      end
      item
        Name = 'GUID'
        DataType = ftString
        ParamType = ptInput
      end
      item
        Name = 'Product_Type'
        DataType = ftInteger
        ParamType = ptInput
      end>
  end
  object UpdSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Update Product_TypeQuestion'
      'Set    Question_Text = :Question_Text,'
      '         Sequence_Reference = :Sequence_Reference,'
      '         Prompt_Type = :Prompt_Type,'
      '         Question_Category = :Question_Category,'
      '         Product_TypeQuestion.inactive = :inactive'
      'Where'
      '(Product_Type = :Product_Type) and'
      '(Question = :Question)'
      '')
    Left = 224
    Top = 24
    ParamData = <
      item
        Name = 'Question_Text'
      end
      item
        Name = 'Sequence_Reference'
      end
      item
        Name = 'Prompt_Type'
        DataType = ftString
      end
      item
        Name = 'Question_Category'
        DataType = ftInteger
      end
      item
        Name = 'inactive'
      end
      item
        Name = 'Product_Type'
      end
      item
        Name = 'Question'
      end>
  end
  object DelSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Delete From Product_TypeQuestion'
