  object AddSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Insert Into Question'
      '        (Question,'
      '        Question_Text)'
      'Select Max(Question)+1, :GUID'
      'From Question'
      ''
      ' ')
    Left = 168
    Top = 24
    ParamData = <
      item
        Name = 'GUID'
        DataType = ftString
        ParamType = ptInput
      end>
  end
  object UpdSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Update Question'
      'Set    Question_Text = :Question_Text,'
      '         Sequence_Reference = :Sequence_Reference,'
      '         Prompt_Type = :Prompt_Type,'
      '         Question_Category = :Question_Category'
      'Where'
      '(Question = :Question)'
      ''
      ' ')
    Left = 224
    Top = 24
    ParamData = <
      item
        Name = 'Question_Text'
      end
      item
        Name = 'Sequence_Reference'
      end
      item
        Name = 'Prompt_Type'
        DataType = ftString
      end
      item
        Name = 'Question_Category'
        DataType = ftInteger
      end
      item
        Name = 'Question'
      end>
  end
