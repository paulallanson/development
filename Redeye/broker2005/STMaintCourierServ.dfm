  object AddSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Insert Into courier_service  (courier,'
      '   service_no,'
      '   service_description,'
      '   service_code,'
      '   Service_Short_Description,'
      '   Deferred_Service,'
      '   inactive)'
      'values'
      '  (:courier,'
      '   :service_no,'
      '   :service_description,'
      '   :service_code,'
      '   :Service_Short_Description,'
      '   :Deferred_Service,'
      '   :inactive)'
      ' ')
    Left = 264
    Top = 32
    ParamData = <
      item
        Name = 'courier'
      end
      item
        Name = 'service_no'
      end
      item
        Name = 'service_description'
      end
      item
        Name = 'service_code'
      end
      item
        Name = 'Service_Short_Description'
      end
      item
        Name = 'Deferred_Service'
      end
      item
        Name = 'inactive'
      end>
  end
  object UpdSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Update courier_service'
      'Set'
      '  service_description = :service_description, '
      '  service_code = :service_code, '
      '  Service_Short_Description = :Service_Short_Description,'
      '  Deferred_Service = :Deferred_Service,'
      '  inactive = :inactive'
      'Where courier = :courier and'
      ' service_no = :service_no;'
      ' ')
    Left = 296
    Top = 32
    ParamData = <
      item
        Name = 'service_description'
      end
      item
        Name = 'service_code'
      end
      item
        Name = 'Service_Short_Description'
      end
      item
        Name = 'Deferred_Service'
      end
      item
        Name = 'inactive'
      end
      item
        Name = 'courier'
      end
      item
        Name = 'service_no'
      end>
  end
  object DelSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Delete From courier_service '
      'where courier = :courier and '
      '  service_no = :service_no;')
    Left = 328
    Top = 32
    ParamData = <
      item
        Name = 'courier'
      end
      item
        Name = 'service_no'
      end>
  end
  object qryGetNextServiceNo: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'select max (service_no) as max_serv_no '
      'from courier_service '
      'where courier = :courier;')
    Left = 416
    Top = 28
    ParamData = <
      item
        Name = 'courier'
      end>
  end
end
