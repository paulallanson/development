  object CheckPOStatusSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Select Purch_Ord.Purch_Ord_Status,'
      '       (Select Count(Purch_Ord_Line_No)'
      '               From Purch_Ord_Line'
      '               Where (Purch_Ord_Line.Purch_Ord = :Purch_Ord) and'
      
        '                     (Purch_Ord_Line.Fully_Received <> '#39'Y'#39')) as ' +
        'No_Not_Deliv,'
      '       (Select Count(Purch_Ord_Line_No)'
      '               From Purch_Ord_Line'
      '               Where (Purch_Ord_Line.Purch_Ord = :Purch_Ord) and'
      
