  object GetLastSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Select Max(Enq_InActive_Reason) as Last_Code'
      'From Enq_InActive_Reason ')
    Left = 192
    Top = 24
  end
  object AddSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Insert Into Enq_InActive_Reason'
      '(Enq_InActive_Reason, Description)'
      'Values'
      '(:Enq_InActive_Reason, :Description)'
      ''
      ' ')
    Left = 72
    Top = 72
    ParamData = <
      item
        Name = 'Enq_InActive_Reason'
      end
      item
        Name = 'Description'
      end>
  end
  object UpdSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Update Enq_InActive_Reason'
      'Set'
      'Description = :Description'
      'Where Enq_InActive_Reason = :Enq_InActive_Reason'
      ' ')
    Left = 144
    Top = 16
    ParamData = <
      item
        Name = 'Description'
      end
      item
        Name = 'Enq_InActive_Reason'
      end>
  end
  object DelSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Delete From Enq_InActive_Reason'
      'Where'
      '(Enq_InActive_Reason = :Enq_InActive_Reason)'
      ' ')
    Left = 240
    Top = 16
    ParamData = <
      item
        Name = 'Enq_InActive_Reason'
      end>
  end
  object DetsSRC: TDataSource
    DataSet = AddSQL
    Left = 320
    Top = 16
  end
  object CheckUniqueRefSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Select Enq_InActive_Reason'
      'From Enq_InActive_Reason'
      'Where (Enq_InActive_Reason <> :Enq_InActive_Reason) and'
      '      (Description = :Description)'
      ' ')
    Left = 72
    Top = 16
    ParamData = <
      item
        Name = 'Enq_InActive_Reason'
        DataType = ftInteger
      end
      item
        Name = 'Description'
      end>
  end
end
