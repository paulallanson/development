  object GetLastSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Select max(Template_no) as Last_Code'
      'From Customer_Product_Template'
      'Where Customer = :Customer')
    Left = 192
    Top = 24
    ParamData = <
      item
        Name = 'Customer'
      end>
  end
  object AddSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Insert Into Customer_Product_Template'
      '        (Customer, '
      '        Template_no,'
      '        Product_Code_Prefix,'
      '        Product_Template)'
      
        'values(:Customer, :Template_no, :Product_Code_Prefix, :Product_T' +
        'emplate)'
      ''
      ''
      ''
      ' '
      ' ')
    Left = 408
    Top = 16
    ParamData = <
      item
        Name = 'Customer'
      end
      item
        Name = 'Template_no'
      end
      item
        Name = 'Product_Code_Prefix'
      end
      item
        Name = 'Product_Template'
      end>
  end
  object UpdSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Update Customer_Product_Template'
      
        '  Set Product_Template = :Product_Template, Product_Code_Prefix ' +
        '= :Product_Code_Prefix '
      'Where'
      '(Customer = :Customer) and (Template_no = :Template_no) '
      ''
      ' ')
    Left = 144
    Top = 16
    ParamData = <
      item
        Name = 'Product_Template'
      end
      item
        Name = 'Product_Code_Prefix'
      end
      item
        Name = 'Customer'
      end
      item
        Name = 'Template_no'
      end>
  end
  object DelSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Delete From Customer_Product_Template'
      'Where'
      '(Customer = :Customer) and (Template_No = :Template_no)'
      ' ')
    Left = 240
    Top = 16
    ParamData = <
      item
        Name = 'Customer'
      end
      item
        Name = 'Template_no'
      end>
  end
  object DetsSRC: TDataSource
    DataSet = AddSQL
    Left = 320
    Top = 16
  end
  object qryZero: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Select Template_No'
      'From Customer_Product_Template'
      'Where (Customer = :Customer) and (Product_Template = :GUID)'
      '')
    Left = 360
    Top = 52
    ParamData = <
      item
        Name = 'Customer'
      end
      item
        Name = 'GUID'
        DataType = ftString
        ParamType = ptInput
      end>
