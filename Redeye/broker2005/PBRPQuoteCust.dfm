      '    ON Price_Unit.Price_Unit = Quote.Price_unit)'
      '    ON Quote_Status.Quote_Status = Quote.Quote_Status)'
      '    ON Rep.Rep = Quote.Rep)'
      '    ON Q.Original_Quote = Quote.Quote'
      'GROUP BY Quote.Quote,'
