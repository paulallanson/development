    ParamData = <
      item
        Name = 'GUID'
        DataType = ftString
        ParamType = ptInput
      end>
  end
  object AddSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Insert Into Courier_Sort'
      '        (Courier_Sort,'
      '        Sort_Description)'
      'Select Max(Courier_Sort)+1, :GUID'
      'From Courier_Sort'
      ' ')
    Left = 280
    Top = 16
    ParamData = <
      item
        Name = 'GUID'
        DataType = ftString
        ParamType = ptInput
      end>
  end
  object UpdSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Update Courier_Sort'
      'Set     Sort_Description = :Sort_Description,'
      '        Inactive = :inactive,'
      '        Courier = :Courier'
      'Where'
      '(Courier_Sort = :Courier_Sort)'
      ''
      ' ')
    Left = 96
    Top = 16
    ParamData = <
      item
        Name = 'Sort_Description'
      end
      item
        Name = 'inactive'
      end
      item
        Name = 'Courier'
      end
      item
        Name = 'Courier_Sort'
      end>
  end
