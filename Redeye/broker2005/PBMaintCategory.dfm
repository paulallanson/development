  object AddSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Insert Into Category'
      '        (Category,'
      '        Description)'
      'Select Max(Category)+1, :GUID'
      'From Category'
      ' ')
    Left = 344
    Top = 96
    ParamData = <
      item
        Name = 'GUID'
        DataType = ftString
        ParamType = ptInput
      end>
  end
  object UpdSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Update Category'
      'Set     Description = :Description,'
      '        Analysis_Code = :Analysis_Code,'
      '        Commission_rate = :Commission_Rate,'
