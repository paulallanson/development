  object GetAllocSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'SELECT Part_Store_Allocation.Quantity_Allocated,'
      '       Part_Store_Allocation.Purch_Ord,'
      '       Purch_Ord.Purch_Ord_No,'
      '       Purch_Ord.Supplier,'
      '       Sales_Order_Line.Sales_Order'
      'FROM (Part_Store_Allocation'
      '           LEFT JOIN Sales_Order_Line'
      
        '                ON (Part_Store_Allocation.Sales_Order = Sales_Or' +
        'der_Line.Sales_Order) and'
      
        '                (Part_Store_Allocation.Sales_Order_line_no = Sal' +
        'es_Order_Line.Sales_Order_line_no))'
      '           LEFT JOIN Purch_Ord'
      
        '                ON Part_Store_Allocation.Purch_Ord = Purch_Ord.P' +
        'urch_Ord'
      'Where (Part_Store_Allocation.Store_Stock = :Store_Stock)'
      'Order By Part_Store_Allocation.Part_Store_Allocation'
      ''
      ' ')
    Left = 80
    Top = 136
    ParamData = <
      item
        Name = 'Store_Stock'
      end>
  end
  object GetStoreStockSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Select *'
      'From Store_Stock'
      'Where Store_Stock = :Store_Stock'
      ' '
      ' '
      ' ')
    Left = 288
    Top = 104
    ParamData = <
      item
        Name = 'Store_Stock'
      end>
  end
  object GetPartSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Select Track_Serial_No, Purch_Pack_Quantity'
      'From Part'
      'Where Part = :Part'
      ' '
      ' ')
    Left = 160
    Top = 112
    ParamData = <
      item
        Name = 'Part'
      end>
  end
  object GetOnOrdSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Select Purch_Ord.Purch_Ord_No, Purch_Ord.Supplier,'
      
        '       Purch_Ord_Line.Purch_Ord_Line_No, Purch_Ord_Line.Purch_Pa' +
        'ck_Quantity,'
      '       Purch_Ord.Purch_Ord,'
      '       (Purch_Ord_Line.Quantity_Ordered -'
      '       Purch_Ord_Line.Quantity_Received) as Qty_On_Order ,'
      
        '       ((Purch_Ord_Line.Quantity_Ordered - Purch_Ord_Line.Quanti' +
        'ty_Received) *'
      
        '                          Purch_Ord_Line.Purchase_Price) as Purc' +
        'h_Value'
      'From Purch_Ord, Purch_Ord_Line'
      'Where (Purch_Ord.Part_Store = :Part_Store) and'
      '      (Purch_Ord_Line.Purch_Ord = Purch_Ord.Purch_Ord) and'
      '      (Purch_Ord_Line.Part = :Part) and'
      '      (Purch_Ord.Purch_Ord_Status <> '#39'R'#39') and'
      '      (Purch_Ord_Line.Fully_Received <> '#39'Y'#39') and'
      
        '      ((Purch_Ord_Line.Quantity_Ordered - Purch_Ord_Line.Quantit' +
        'y_Received) > 0)'
      ''
      ' ')
    Left = 208
    Top = 192
    ParamData = <
      item
        Name = 'Part_Store'
      end
      item
        Name = 'Part'
      end>
  end
  object GetOnOrdAllocSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Select Sales_Order_Line.Quantity_Ordered,'
      '       Sales_Order_Line.Sales_order,'
      '       Sales_order_Line.Sales_Order_Line_no'
      'From  Purch_Ord_Line_Alloc, Sales_order_Line'
      'Where (Purch_Ord_Line_Alloc.Purch_Ord = :Purch_Ord) and'
      
        '      (Purch_Ord_Line_Alloc.Purch_Ord_Line_No = :Purch_Ord_Line_' +
        'No) and'
      '      ('
      
        '      (Sales_Order_Line.Sales_order = Purch_Ord_Line_Alloc.Sales' +
        '_Order) and'
      
        '      (Sales_Order_Line.Sales_order_line_no = Purch_Ord_Line_All' +
        'oc.Sales_order_line_no)'
      '      )'
      ' '
      ' ')
    Left = 160
    Top = 192
    ParamData = <
      item
        Name = 'Purch_Ord'
      end
      item
        Name = 'Purch_Ord_Line_No'
      end>
  end
  object GetStoresSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Select Part_Store, Part_Store_Name'
      'From Part_Store'
      'Order By Part_Store_Name'
      ''
      ' '
      ' ')
    Left = 200
    Top = 80
  end
