  object GetStockSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Select Store_Stock.Part_Bin, Store_Stock.Part_Store_Lot,'
      
        '       Store_Stock.Store_Quantity, Store_Stock.Quantity_Allocate' +
        'd,'
      '       Store_Stock.Store_Cost,'
      
        '       Store_Stock.Store_Stock , Store_Stock.Stock_Pack_Quantity' +
        ', '
      '       store_stock.invoice_upfront'
      'From  Store_Stock'
      'Where (Store_Stock.Part = :Part) and'
      '      (Store_Stock.Part_Store = :Part_Store)'
      'Order by Store_Stock.Part_Bin, Store_Stock.Part_Store_Lot'
      ''
      ''
      ''
      ''
      ' '
      ' ')
    Left = 328
    Top = 104
    ParamData = <
      item
        Name = 'Part'
      end
      item
        Name = 'Part_Store'
      end>
  end
