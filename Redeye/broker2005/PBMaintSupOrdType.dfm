      end
      item
        Name = 'Supp_Order_Desc'
      end>
  end
  object UpdSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Update Supplier_Order_Type'
      'Set'
      '  Supp_Order_Desc=:Supp_Order_Desc'
      'Where Supplier = :Supplier and'
      'Supp_Order_type=:Supp_Order_type'
      '')
    Left = 312
    ParamData = <
      item
        Name = 'Supp_Order_Desc'
      end
      item
        Name = 'Supplier'
      end
      item
        Name = 'Supp_Order_type'
      end>
  end
