  object AddSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Insert Into Supplier_Order_Type'
      '  (Supplier,'
      '   Supp_Order_Type,'
      '   Supp_Order_Desc)'
      'values'
      '  (:Supplier,'
      '   :Supp_Order_Type,'
      '   :Supp_Order_Desc)')
