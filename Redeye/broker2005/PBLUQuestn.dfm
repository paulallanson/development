  object GetDetsSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Select  Question.Question,'
      '        Question.Question_Text,'
      '        Question.Sequence_Reference,'
      '        Question.Prompt_type,'
      '        Question.Question_Category'
      'From Question'
      'Where (Question.Question_Text Like :Code_From)'
      'Order By Question.Sequence_Reference')
    Left = 40
    Top = 16
    ParamData = <
      item
        Name = 'Code_From'
        DataType = ftString
      end>
  end
