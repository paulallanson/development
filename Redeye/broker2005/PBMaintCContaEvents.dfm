  object AddSQL: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'Insert Into Customer_Contact_Event'
      '        (Customer,'
      '        Branch_No,'
      '        Contact_No,'
      '        Customer_Cont_Event_No,'
      '        Event_GUID)'
      
        'Select :Customer, :Branch_No, :Contact_No, Max(Customer_Cont_Eve' +
        'nt_No)+1,:Event_GUID'
      'From Customer_Contact_Event'
      'Where (Customer = :Customer) and'
      '      (Branch_No = :Branch_No) and'
      '      (Contact_No = :Contact_No)'
      ' '
      ' ')
    Left = 72
    Top = 272
    ParamData = <
      item
        Name = 'Customer'
        DataType = ftInteger
        ParamType = ptInput
      end
      item
        Name = 'Branch_No'
        DataType = ftInteger
        ParamType = ptInput
      end
      item
        Name = 'Contact_No'
      end
      item
        Name = 'Event_GUID'
      end
      item
        Name = 'Customer'
        DataType = ftInteger
        ParamType = ptInput
      end
      item
        Name = 'Branch_No'
        DataType = ftInteger
        ParamType = ptInput
      end
      item
        Name = 'Contact_No'
      end>
  end
