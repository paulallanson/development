  object qrySalesProfit: TFDQuery
    ConnectionName = 'PB'
    SQL.Strings = (
      'select '#9'Sales_profit.rep,'
      #9'rep.Name as Rep_Name,'
      #9'Sales_profit.Purchase_order,'
      #9'Sales_profit.Line,'
      '  '#9'Sales_profit.Sales_order,'
      #9'Customer.Name as Customer_Name,'
      #9'Supplier.Name as Supplier_Name,'
      #9'sum(Total_Sales_Value) as Sales_Value,'
      #9'sum(Total_Cost_Value) as Cost_Value,'
      '                Job_Bag'
      'from '#9'sales_profit, '
      #9'rep, '
      #9'Customer, '
      #9'Supplier'
      'Where Sales_Profit.rep = rep.rep and'
      #9'(Sales_profit.Customer = Customer.Customer) and'
      #9'(Sales_profit.Supplier = Supplier.Supplier)'
      'group by'
      #9'sales_profit.rep,'
      #9'rep.Name,'
      #9'Sales_profit.Purchase_order,'
      #9'Sales_profit.Line,'
      '  '#9'Sales_profit.Sales_order,'
      #9'Customer.Name,'
      #9'Supplier.Name,'
      '                Job_Bag'
      'order by rep.Name')
    Left = 24
    Top = 8
  end
