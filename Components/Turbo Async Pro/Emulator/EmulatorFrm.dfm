  object SockPort: TApdWinsockPort
    WsLocalAddresses.Strings = (
      '192.168.0.4')
    WsLocalAddressIndex = 0
    WsPort = 'telnet'
    WsSocksServerInfo.Port = 0
    AutoOpen = False
    ComNumber = 2
    TraceName = 'APRO.TRC'
    LogSize = 0
    LogName = 'APRO.LOG'
    OnWsConnect = SockPortWsConnect
    OnWsDisconnect = SockPortWsDisconnect
    OnWsError = SockPortWsError
    OnTriggerData = SockPortTriggerData
    Left = 608
    Top = 180
  end
  object XferProtocol: TApdProtocol
    ComPort = SockPort
    ProtocolType = ptZmodem
    DestinationDirectory = 'c:\tmp'
    FileMask = '*.*'
    BlockCheckMethod = bcmCrc32
    HandshakeWait = 1092
    Overhead = 20
    WriteFailAction = wfWriteAnyway
    StatusDisplay = XferStatus
    ProtocolLog = XferLog
    StatusInterval = 10
    KermitPadCharacter = #0
    OnProtocolFinish = XferProtocolProtocolFinish
    Left = 608
    Top = 72
  end
